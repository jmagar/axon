{
  "mcpServers": {
    "axon": {
      "command": "bash",
      "args": [
        "-lc",
        "REPO_ROOT=\"${AXON_REPO_ROOT:-$PWD}\" && cd \"$REPO_ROOT\" && set -a && source ./.env && set +a && export AXON_LITE=\"${AXON_LITE:-0}\" && export AXON_MCP_TRANSPORT=stdio && export AXON_PG_URL=\"${AXON_PG_MCP_URL:-${AXON_PG_URL:-}}\" && exec ./target/debug/axon mcp"
      ],
      "env": {
        "AXON_DATA_DIR": ".cache/mcporter-runtime",
        "AXON_MCP_TRANSPORT": "stdio",
        "AXON_LOG_FILE": ".cache/mcporter-runtime/axon/logs/axon.log",
        "AXON_SQLITE_PATH": ".cache/mcporter-runtime/axon/mcporter-jobs.db"
      }
    },
    "plate": {
      "description": "Plate editors, plugins and components",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "env": {
        "npm_config_cache": "${HOME}/.cache/axon-mcporter-npm"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "npm_config_cache": "${HOME}/.cache/axon-mcporter-npm"
      }
    }
  },
  "imports": []
}