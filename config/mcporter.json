{
  "mcpServers": {
    "axon": {
      "command": "bash",
      "args": [
        "-lc",
        "exec \"${AXON_REPO_ROOT:-$PWD}/scripts/mcporter-axon\""
      ],
      "env": {
        "AXON_MCP_TRANSPORT": "stdio"
      }
    },
    "plate": {
      "description": "Plate editors, plugins and components",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "env": {
        "npm_config_cache": "${HOME}/.cache/axon-mcporter-npm"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "npm_config_cache": "${HOME}/.cache/axon-mcporter-npm"
      }
    }
  },
  "imports": []
}
