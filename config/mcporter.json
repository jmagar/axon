{
  "mcpServers": {
    "axon-axon": {
      "command": "axon",
      "args": [
        "mcp"
      ],
      "env": {
        "AXON_MCP_TRANSPORT": "stdio"
      }
    },
    "plate": {
      "description": "Plate editors, plugins and components",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  },
  "imports": []
}
