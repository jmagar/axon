{
  "contract_version": "1.0.0",
  "source_doc": "docs/pipeline-unification/surfaces/presentation-contract.md",
  "colors": [
    { "name": "background", "dark": "#07131c", "light": "#f0f6f8", "note": "aurora-page-bg" },
    { "name": "surface", "dark": "#102330", "light": "#ffffff", "note": "aurora-panel-medium" },
    { "name": "surface_raised", "dark": "#13293a", "light": "#f8fbfc", "note": "solid proxy for aurora-surface-raised gradient; CSS platforms may reference the gradient var directly" },
    { "name": "border", "dark": "#1d3d4e", "light": "#b8d0da", "note": "aurora-border-default" },
    { "name": "divider", "dark": "#1d3d4e", "light": "#b8d0da", "note": "alias of border (aurora has no separate low-emphasis divider color)" },
    { "name": "text_primary", "dark": "#e6f4fb", "light": "#07131c", "note": "aurora-text-primary" },
    { "name": "text_secondary", "dark": "#a7bcc9", "light": "#3d6070", "note": "alias of text_muted (aurora has only one secondary text tier)" },
    { "name": "text_muted", "dark": "#a7bcc9", "light": "#3d6070", "note": "aurora-text-muted" },
    { "name": "text_inverse", "dark": "#051520", "light": "#ffffff", "note": "aurora-accent-foreground" },
    { "name": "accent", "dark": "#29b6f6", "light": "#0288d1", "note": "aurora-accent-primary" },
    { "name": "accent_strong", "dark": "#67cbfa", "light": "#0277bd", "note": "aurora-accent-strong" },
    { "name": "service_name", "dark": "#f9a8c4", "light": "#d63a6f", "note": "aurora-accent-pink (rose identity)" },
    { "name": "automation", "dark": "#a78bfa", "light": "#7c3aed", "note": "aurora-accent-violet (AI/automation identity)" },
    { "name": "success", "dark": "#7dd3c7", "light": "#2d7d6e", "note": "aurora-success" },
    { "name": "warning", "dark": "#c6a36b", "light": "#8a6914", "note": "aurora-warn" },
    { "name": "error", "dark": "#c78490", "light": "#9c3545", "note": "aurora-error" },
    { "name": "info", "dark": "#72c8f5", "light": "#0f7db8", "note": "aurora-info" },
    { "name": "neutral", "dark": "#91a8b6", "light": "#6f8793", "note": "aurora-neutral" },
    { "name": "waiting", "dark": "#72c8f5", "light": "#0f7db8", "note": "alias of info (waiting/backpressure has no distinct Aurora hex)" },
    { "name": "degraded", "dark": "#c6a36b", "light": "#8a6914", "note": "alias of warning (contract forbids red for degraded states)" },
    { "name": "source", "dark": "#29b6f6", "light": "#0288d1", "note": "object-identity alias of accent" },
    { "name": "job", "dark": "#72c8f5", "light": "#0f7db8", "note": "object-identity alias of info" },
    { "name": "graph", "dark": "#a78bfa", "light": "#7c3aed", "note": "object-identity alias of automation" },
    { "name": "memory", "dark": "#f9a8c4", "light": "#d63a6f", "note": "object-identity alias of service_name" },
    { "name": "artifact", "dark": "#67cbfa", "light": "#0277bd", "note": "object-identity alias of accent_strong" },
    { "name": "provider", "dark": "#91a8b6", "light": "#6f8793", "note": "object-identity alias of neutral" },
    { "name": "focus_ring", "dark": "#29b6f6", "light": "#0288d1", "note": "solid base for aurora-focus-ring color-mix; CSS platforms may apply the mix" },
    { "name": "hover", "dark": "#17364b", "light": "#dceef4", "note": "aurora-hover-bg" },
    { "name": "selected", "dark": "#29b6f6", "light": "#0288d1", "note": "solid base for aurora-selected-bg color-mix; CSS platforms may apply the mix" },
    { "name": "disabled", "dark": "#a7bcc9", "light": "#3d6070", "note": "solid base for aurora-disabled-text/-surface color-mix" }
  ],
  "typography": {
    "font_family_sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
    "font_family_mono": "'JetBrains Mono', 'IBM Plex Mono', ui-monospace, Menlo, monospace",
    "font_family_display": "'Manrope', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
    "font_size_xs": 11,
    "font_size_sm": 13,
    "font_size_md": 14,
    "font_size_lg": 18,
    "font_size_xl": 24,
    "font_weight_regular": 480,
    "font_weight_medium": 560,
    "font_weight_semibold": 760,
    "line_height_tight": 1.28,
    "line_height_normal": 1.58,
    "line_height_relaxed": 1.58
  },
  "spacing": { "space_1": 4, "space_2": 8, "space_3": 12, "space_4": 16, "space_5": 20, "space_6": 24, "space_7": 32, "space_8": 40 },
  "radius": { "xs": 14, "sm": 18, "md": 22 },
  "density": { "compact": "compact", "comfortable": "comfortable", "cozy": "cozy" },
