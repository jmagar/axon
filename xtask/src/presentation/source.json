    { "status": "completed", "token": "success" },
    { "status": "completed_degraded", "token": "degraded" },
    { "status": "failed", "token": "error" },
    { "status": "canceled", "token": "neutral" },
    { "status": "waiting", "token": "waiting" },
    { "status": "blocked", "token": "warning" },
    { "status": "running", "token": "info_or_accent" },
    { "status": "queued_pending", "token": "neutral" }
  ],
  "icons": [
    { "intent": "success", "slot": "icon.success", "cli_symbol": "ok" },
    { "intent": "warning", "slot": "icon.warning", "cli_symbol": "!" },
    { "intent": "error", "slot": "icon.error", "cli_symbol": "x" },
    { "intent": "source", "slot": "icon.source", "cli_symbol": "src" },
    { "intent": "job", "slot": "icon.job", "cli_symbol": "job" },
    { "intent": "graph", "slot": "icon.graph", "cli_symbol": "graph" },
    { "intent": "memory", "slot": "icon.memory", "cli_symbol": "mem" },
    { "intent": "artifact", "slot": "icon.artifact", "cli_symbol": "file" },
    { "intent": "provider", "slot": "icon.provider", "cli_symbol": "svc" },
    { "intent": "refresh", "slot": "icon.refresh", "cli_symbol": "refresh" },
    { "intent": "watch", "slot": "icon.watch", "cli_symbol": "watch" },
    { "intent": "prune", "slot": "icon.prune", "cli_symbol": "prune" },
    { "intent": "search", "slot": "icon.search", "cli_symbol": "search" },
    { "intent": "ask", "slot": "icon.ask", "cli_symbol": "ask" }
  ]
}
