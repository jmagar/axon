# Standalone axon_cli extraction: keep build context small.
/.git
/.github
/.cache
/.serena
/.1code
/.claude
/.codex
/.gemini
/target
/docs
/storage
/data
/specs
/.full-review
http-cacache/
/logs
/docker-build.log

# Frontend source is required by config/Dockerfile to build RustEmbed assets.
/apps
!/apps
/apps/*
!/apps/web
/apps/web/node_modules
/apps/web/.next
**/node_modules

**/.DS_Store
**/*.log
**/*.tmp

# Secrets — never bake into the image; inject at runtime via env vars or Docker secrets.
.env
.env.*
!.env.example
