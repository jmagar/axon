{
  "$defs": {
    "ApiError": {
      "$defs": {
        "ErrorCode": {
          "description": "A stable, machine-readable error code (e.g. `provider.unavailable`).",
          "type": "string"
        },
        "ErrorSeverity": {
          "description": "How severe an error is and whether it terminates the item/job.",
          "oneOf": [
            {
              "const": "info",
              "description": "Informational event; not terminal.",
              "type": "string"
            },
            {
              "const": "warning",
              "description": "Non-fatal issue, full behavior preserved; not terminal.",
              "type": "string"
            },
            {
              "const": "degraded",
              "description": "Behavior reduced but acceptable by policy; may or may not be terminal.",
              "type": "string"
            },
            {
              "const": "failed",
              "description": "Required work failed; terminal for the affected item/job.",
              "type": "string"
            },
            {
              "const": "fatal",
              "description": "Cannot continue safely; terminal.",
              "type": "string"
            }
          ]
        },
        "ErrorStage": {
          "description": "Pipeline/transport stage an error is attributed to.",
          "oneOf": [
            {
              "const": "parsing",
              "description": "CLI/MCP/REST request parse, removed command/action.",
              "type": "string"
            },
            {
              "const": "validation",
              "description": "Missing fields, bad types, unsupported flags.",
              "type": "string"
            },
            {
              "const": "resolving",
              "description": "Source resolution, canonical URI, authority.",
              "type": "string"
            },
            {
              "const": "routing",
              "description": "Adapter/scope/provider selection.",
              "type": "string"
            },
            {
              "const": "authorizing",
              "description": "Auth, credentials, execution policy.",
              "type": "string"
            },
            {
              "const": "planning",
              "description": "Source plan, prune plan.",
              "type": "string"
            },
            {
              "const": "leasing",
              "description": "Job/watch/source lease.",
              "type": "string"
            },
            {
              "const": "discovering",
              "description": "Manifest/map discovery.",
              "type": "string"
            },
            {
              "const": "diffing",
              "description": "Manifest diff.",
              "type": "string"
            },
            {
              "const": "fetching",
              "description": "HTTP/git/package/local/MCP/CLI fetch.",
              "type": "string"
            },
            {
              "const": "rendering",
              "description": "Browser/CDP/render provider.",
              "type": "string"
            },
            {
              "const": "normalizing",
              "description": "SourceDocument creation.",
              "type": "string"
            },
            {
              "const": "parsing_content",
              "description": "Parser facts/chunk parser (serialized as `parsing_content`).",
              "type": "string"
            },
            {
              "const": "graphing",
              "description": "Graph writes/merge/conflict.",
              "type": "string"
            },
            {
              "const": "preparing",
              "description": "Chunking/PreparedDocument.",
              "type": "string"
            },
            {
              "const": "embedding",
              "description": "Embedding provider/batch.",
              "type": "string"
            },
            {
              "const": "upserting",
              "description": "VectorStore writes.",
              "type": "string"
            },
            {
              "const": "publishing",
              "description": "Generation publish.",
              "type": "string"
            },
            {
              "const": "cleaning",
              "description": "Cleanup/prune/dedupe.",
              "type": "string"
            },
            {
              "const": "retrieving",
              "description": "Query/retrieve context.",
              "type": "string"
            },
            {
              "const": "synthesizing",
              "description": "LLM synthesis.",
              "type": "string"
            },
            {
              "const": "observing",
              "description": "Progress/log/status emit.",
              "type": "string"
            }
          ]
        },
        "ErrorVisibility": {
          "description": "Where a context entry (or error) may be surfaced.\n\nFrom the \"visibility\" field in the error shape: `public`, `internal`,\n`sensitive`.",
          "oneOf": [
            {
              "const": "public",
              "description": "Safe to render to any caller, including remote/unauthenticated.",
              "type": "string"
            },
            {
              "const": "internal",
              "description": "Internal diagnostics; render only to internal/admin surfaces.",
              "type": "string"
            },
            {
              "const": "sensitive",
              "description": "Sensitive/secret-adjacent; never render raw, redaction required.",
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "The shared, transport-neutral error shape.\n\nEvery crate reports failures as an `ApiError` so CLI, REST, MCP, jobs, logs,\nand progress streams render one consistent structure.",
      "properties": {
        "chunk_id": {
          "description": "Chunk id.",
          "type": [
            "string",
            "null"
          ]
        },
        "code": {
          "$ref": "#/$defs/ErrorCode",
          "description": "Stable machine code (e.g. `provider.unavailable`)."
        },
        "cooldown_until": {
          "description": "Provider/job cooling timestamp.",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "details": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Redacted structured context (safe key/value pairs only).",
          "type": "object"
        },
        "document_id": {
          "description": "Document id.",
          "type": [
            "string",
            "null"
          ]
        },
        "job_id": {
          "description": "Job correlation id.",
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "description": "Redacted human-readable message.",
          "type": "string"
        },
        "provider_id": {
          "description": "Provider that failed.",
          "type": [
            "string",
            "null"
          ]
        },
        "retry_after_ms": {
          "description": "Suggested retry delay, in milliseconds.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "retryable": {
          "description": "Whether retry may succeed.",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ErrorSeverity",
          "description": "Severity classification."
        },
        "source_id": {
          "description": "Source id.",
          "type": [
            "string",
            "null"
          ]
        },
        "source_item_key": {
          "description": "Item/file/page key.",
          "type": [
            "string",
            "null"
          ]
        },
        "stage": {
          "$ref": "#/$defs/ErrorStage",
          "description": "Pipeline/transport stage."
        },
        "visibility": {
          "$ref": "#/$defs/ErrorVisibility",
          "description": "Where this error may be surfaced."
        }
      },
      "required": [
        "code",
        "message",
        "stage",
        "retryable",
        "severity",
        "visibility",
        "details"
      ],
      "title": "ApiError",
      "type": "object"
    },
    "ResolvedSource": {
      "$defs": {
        "AdapterCandidate": {
          "additionalProperties": false,
          "properties": {
            "adapter": {
              "$ref": "#/$defs/AdapterRef"
            },
            "confidence": {
              "format": "float",
              "type": "number"
            },
            "reason": {
              "type": "string"
            },
            "supported_scopes": {
              "items": {
                "$ref": "#/$defs/SourceScope"
              },
              "type": "array"
            }
          },
          "required": [
            "adapter",
            "supported_scopes",
            "confidence",
            "reason"
          ],
          "type": "object"
        },
        "AdapterRef": {
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "version"
          ],
          "type": "object"
        },
        "AuthorityLevel": {
          "enum": [
            "official",
            "verified",
            "user_pinned",
            "inferred",
            "community",
            "mirror",
            "conflicting",
            "unknown"
          ],
          "type": "string"
        },
        "Severity": {
          "enum": [
            "debug",
            "info",
            "warning",
            "degraded",
            "failed",
            "fatal"
          ],
          "type": "string"
        },
        "SourceId": {
          "type": "string"
        },
        "SourceItemKey": {
          "type": "string"
        },
        "SourceKind": {
          "enum": [
            "web",
            "local",
            "git",
            "registry",
            "feed",
            "reddit",
            "youtube",
            "session",
            "cli_tool",
            "mcp_tool",
            "memory",
            "upload"
          ],
          "type": "string"
        },
        "SourceScope": {
          "enum": [
            "page",
            "site",
            "docs",
            "repo",
            "workspace",
            "branch",
            "org",
            "package",
            "version",
            "feed",
            "subreddit",
            "thread",
            "comment",
            "video",
            "playlist",
            "channel",
            "issue",
            "pull_request",
            "merge_request",
            "release",
            "wiki",
            "file",
            "directory",
            "map",
            "tool",
            "script",
            "api"
          ],
          "type": "string"
        },
        "SourceWarning": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "retryable": {
              "type": "boolean"
            },
            "severity": {
              "$ref": "#/$defs/Severity"
            },
            "source_item_key": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceItemKey"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "code",
            "severity",
            "message",
            "retryable"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "authority": {
          "$ref": "#/$defs/AuthorityLevel"
        },
        "available_scopes": {
          "items": {
            "$ref": "#/$defs/SourceScope"
          },
          "type": "array"
        },
        "candidate_adapters": {
          "items": {
            "$ref": "#/$defs/AdapterCandidate"
          },
          "type": "array"
        },
        "canonical_uri": {
          "type": "string"
        },
        "confidence": {
          "format": "float",
          "type": "number"
        },
        "default_scope": {
          "$ref": "#/$defs/SourceScope"
        },
        "display_name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "requested_uri": {
          "type": "string"
        },
        "source_id": {
          "$ref": "#/$defs/SourceId"
        },
        "source_kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/SourceWarning"
          },
          "type": "array"
        }
      },
      "required": [
        "requested_uri",
        "canonical_uri",
        "source_id",
        "source_kind",
        "display_name",
        "candidate_adapters",
        "default_scope",
        "available_scopes",
        "authority",
        "confidence",
        "reason",
        "warnings"
      ],
      "title": "ResolvedSource",
      "type": "object"
    },
    "SourceRequest": {
      "$defs": {
        "AdapterOptions": {
          "additionalProperties": false,
          "properties": {
            "values": {
              "additionalProperties": true,
              "type": "object"
            }
          },
          "required": [
            "values"
          ],
          "type": "object"
        },
        "ArtifactMode": {
          "enum": [
            "none",
            "on_large_output",
            "always"
          ],
          "type": "string"
        },
        "AuthorityEvidence": {
          "additionalProperties": false,
          "properties": {
            "confidence": {
              "format": "float",
              "type": "number"
            },
            "evidence_kind": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "evidence_kind",
            "value",
            "confidence"
          ],
          "type": "object"
        },
        "AuthorityHint": {
          "additionalProperties": false,
          "properties": {
            "authority": {
              "$ref": "#/$defs/AuthorityLevel"
            },
            "canonical_uri": {
              "type": [
                "string",
                "null"
              ]
            },
            "evidence": {
              "items": {
                "$ref": "#/$defs/AuthorityEvidence"
              },
              "type": "array"
            }
          },
          "required": [
            "authority",
            "evidence"
          ],
          "type": "object"
        },
        "AuthorityLevel": {
          "enum": [
            "official",
            "verified",
            "user_pinned",
            "inferred",
            "community",
            "mirror",
            "conflicting",
            "unknown"
          ],
          "type": "string"
        },
        "ExecutionMode": {
          "enum": [
            "foreground",
            "background",
            "wait"
          ],
          "type": "string"
        },
        "ExecutionPolicy": {
          "additionalProperties": false,
          "properties": {
            "detached": {
              "type": "boolean"
            },
            "heartbeat_interval_secs": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "mode": {
              "$ref": "#/$defs/ExecutionMode"
            },
            "priority": {
              "$ref": "#/$defs/JobPriority"
            },
            "wait_timeout_secs": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [
            "mode",
            "priority",
            "detached",
            "heartbeat_interval_secs"
          ],
          "type": "object"
        },
        "JobPriority": {
          "enum": [
            "interactive",
            "high",
            "normal",
            "background",
            "maintenance"
          ],
          "type": "string"
        },
        "OutputPolicy": {
          "additionalProperties": false,
          "properties": {
            "artifact_mode": {
              "$ref": "#/$defs/ArtifactMode"
            },
            "include_progress": {
              "type": "boolean"
            },
            "inline_limit_bytes": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "json": {
              "type": "boolean"
            },
            "response_mode": {
              "$ref": "#/$defs/ResponseMode"
            }
          },
          "required": [
            "json",
            "response_mode",
            "inline_limit_bytes",
            "artifact_mode",
            "include_progress"
          ],
          "type": "object"
        },
        "ResponseMode": {
          "enum": [
            "auto",
            "summary",
            "full",
            "inline",
            "artifact",
            "path",
            "job_only"
          ],
          "type": "string"
        },
        "SourceIntent": {
          "enum": [
            "acquire",
            "refresh",
            "watch",
            "map"
          ],
          "type": "string"
        },
        "SourceLimits": {
          "additionalProperties": false,
          "properties": {
            "max_bytes_per_item": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "max_chunks": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "max_depth": {
              "format": "uint32",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "max_items": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "max_pages": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "max_total_bytes": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "provider_timeout_ms": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "type": "object"
        },
        "SourceRefreshPolicy": {
          "enum": [
            "if_stale",
            "force",
            "never"
          ],
          "type": "string"
        },
        "SourceScope": {
          "enum": [
            "page",
            "site",
            "docs",
            "repo",
            "workspace",
            "branch",
            "org",
            "package",
            "version",
            "feed",
            "subreddit",
            "thread",
            "comment",
            "video",
            "playlist",
            "channel",
            "issue",
            "pull_request",
            "merge_request",
            "release",
            "wiki",
            "file",
            "directory",
            "map",
            "tool",
            "script",
            "api"
          ],
          "type": "string"
        },
        "SourceWatchPolicy": {
          "enum": [
            "disabled",
            "ensure",
            "enabled"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": [
            "string",
            "null"
          ]
        },
        "authority_hint": {
          "anyOf": [
            {
              "$ref": "#/$defs/AuthorityHint"
            },
            {
              "type": "null"
            }
          ]
        },
        "collection": {
          "type": [
            "string",
            "null"
          ]
        },
        "embed": {
          "default": true,
          "type": "boolean"
        },
        "execution": {
          "$ref": "#/$defs/ExecutionPolicy",
          "default": {
            "detached": false,
            "heartbeat_interval_secs": 5,
            "mode": "background",
            "priority": "normal"
          }
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "intent": {
          "$ref": "#/$defs/SourceIntent",
          "default": "acquire"
        },
        "limits": {
          "$ref": "#/$defs/SourceLimits",
          "default": {}
        },
        "metadata": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "options": {
          "$ref": "#/$defs/AdapterOptions",
          "default": {
            "values": {}
          }
        },
        "output": {
          "$ref": "#/$defs/OutputPolicy",
          "default": {
            "artifact_mode": "on_large_output",
            "include_progress": false,
            "inline_limit_bytes": 65536,
            "json": false,
            "response_mode": "auto"
          }
        },
        "refresh": {
          "$ref": "#/$defs/SourceRefreshPolicy",
          "default": "if_stale"
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceScope"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "type": "string"
        },
        "watch": {
          "$ref": "#/$defs/SourceWatchPolicy",
          "default": "disabled"
        }
      },
      "required": [
        "source"
      ],
      "title": "SourceRequest",
      "type": "object"
    },
    "SourceResult": {
      "$defs": {
        "AdapterRef": {
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "version"
          ],
          "type": "object"
        },
        "ArtifactId": {
          "type": "string"
        },
        "ArtifactKind": {
          "enum": [
            "raw_content",
            "normalized_content",
            "manifest",
            "report",
            "screenshot",
            "warc",
            "provider_trace"
          ],
          "type": "string"
        },
        "ArtifactRef": {
          "additionalProperties": false,
          "properties": {
            "artifact_id": {
              "$ref": "#/$defs/ArtifactId"
            },
            "artifact_kind": {
              "$ref": "#/$defs/ArtifactKind"
            },
            "content_hash": {
              "type": [
                "string",
                "null"
              ]
            },
            "created_at": {
              "type": "string"
            },
            "size_bytes": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "uri": {
              "type": "string"
            }
          },
          "required": [
            "artifact_id",
            "artifact_kind",
            "uri",
            "created_at"
          ],
          "type": "object"
        },
        "ContentRef": {
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "inline_text",
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "text"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "bytes_base64": {
                  "type": "string"
                },
                "kind": {
                  "const": "inline_bytes",
                  "type": "string"
                },
                "mime_type": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "bytes_base64",
                "mime_type"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "artifact_id": {
                  "$ref": "#/$defs/ArtifactId"
                },
                "kind": {
                  "const": "artifact",
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "artifact_id"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "integrity": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "kind": {
                  "const": "external",
                  "type": "string"
                },
                "uri": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "uri"
              ],
              "type": "object"
            }
          ]
        },
        "GraphWriteSummary": {
          "additionalProperties": false,
          "properties": {
            "degraded": {
              "type": "boolean"
            },
            "edges_upserted": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "evidence_records": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "nodes_upserted": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "nodes_upserted",
            "edges_upserted",
            "evidence_records",
            "degraded"
          ],
          "type": "object"
        },
        "InlineSourceResult": {
          "additionalProperties": false,
          "properties": {
            "content": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ContentRef"
