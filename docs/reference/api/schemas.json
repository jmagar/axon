{
  "$defs": {
    "ApiError": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "The shared, transport-neutral error shape.\n\nEvery crate reports failures as an `ApiError` so CLI, REST, MCP, jobs, logs,\nand progress streams render one consistent structure.",
      "properties": {
        "chunk_id": {
          "description": "Chunk id.",
          "type": [
            "string",
            "null"
          ]
        },
        "code": {
          "$ref": "#/$defs/ApiError_ErrorCode",
          "description": "Stable machine code (e.g. `provider.unavailable`)."
        },
        "cooldown_until": {
          "description": "Provider/job cooling timestamp.",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "details": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Redacted structured context (safe key/value pairs only).",
          "type": "object"
        },
        "document_id": {
          "description": "Document id.",
          "type": [
            "string",
            "null"
          ]
        },
        "job_id": {
          "description": "Job correlation id.",
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "description": "Redacted human-readable message.",
          "type": "string"
        },
        "provider_id": {
          "description": "Provider that failed.",
          "type": [
            "string",
            "null"
          ]
        },
        "retry_after_ms": {
          "description": "Suggested retry delay, in milliseconds.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "retryable": {
          "description": "Whether retry may succeed.",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ApiError_ErrorSeverity",
          "description": "Severity classification."
        },
        "source_id": {
          "description": "Source id.",
          "type": [
            "string",
            "null"
          ]
        },
        "source_item_key": {
          "description": "Item/file/page key.",
          "type": [
            "string",
            "null"
          ]
        },
        "stage": {
          "$ref": "#/$defs/ApiError_ErrorStage",
          "description": "Pipeline/transport stage."
        },
        "visibility": {
          "$ref": "#/$defs/ApiError_ErrorVisibility",
          "description": "Where this error may be surfaced."
        }
      },
      "required": [
        "code",
        "message",
        "stage",
        "retryable",
        "severity",
        "visibility",
        "details"
      ],
      "title": "ApiError",
      "type": "object"
    },
    "ApiError_ErrorCode": {
      "description": "A stable, machine-readable error code (e.g. `provider.unavailable`).",
      "type": "string"
    },
    "ApiError_ErrorSeverity": {
      "description": "How severe an error is and whether it terminates the item/job.",
      "oneOf": [
        {
          "const": "info",
          "description": "Informational event; not terminal.",
          "type": "string"
        },
        {
          "const": "warning",
          "description": "Non-fatal issue, full behavior preserved; not terminal.",
          "type": "string"
        },
        {
          "const": "degraded",
          "description": "Behavior reduced but acceptable by policy; may or may not be terminal.",
          "type": "string"
        },
        {
          "const": "failed",
          "description": "Required work failed; terminal for the affected item/job.",
          "type": "string"
        },
        {
          "const": "fatal",
          "description": "Cannot continue safely; terminal.",
          "type": "string"
        }
      ]
    },
    "ApiError_ErrorStage": {
      "description": "Pipeline/transport stage an error is attributed to.",
      "oneOf": [
        {
          "const": "parsing",
          "description": "CLI/MCP/REST request parse, removed command/action.",
          "type": "string"
        },
        {
          "const": "validation",
          "description": "Missing fields, bad types, unsupported flags.",
          "type": "string"
        },
        {
          "const": "resolving",
          "description": "Source resolution, canonical URI, authority.",
          "type": "string"
        },
        {
          "const": "routing",
          "description": "Adapter/scope/provider selection.",
          "type": "string"
        },
        {
          "const": "authorizing",
          "description": "Auth, credentials, execution policy.",
          "type": "string"
        },
        {
          "const": "planning",
          "description": "Source plan, prune plan.",
          "type": "string"
        },
        {
          "const": "leasing",
          "description": "Job/watch/source lease.",
          "type": "string"
        },
        {
          "const": "discovering",
          "description": "Manifest/map discovery.",
          "type": "string"
        },
        {
          "const": "diffing",
          "description": "Manifest diff.",
          "type": "string"
        },
        {
          "const": "fetching",
          "description": "HTTP/git/package/local/MCP/CLI fetch.",
          "type": "string"
        },
        {
          "const": "rendering",
          "description": "Browser/CDP/render provider.",
          "type": "string"
        },
        {
          "const": "normalizing",
          "description": "SourceDocument creation.",
          "type": "string"
        },
        {
          "const": "parsing_content",
          "description": "Parser facts/chunk parser (serialized as `parsing_content`).",
          "type": "string"
        },
        {
          "const": "graphing",
          "description": "Graph writes/merge/conflict.",
          "type": "string"
        },
        {
          "const": "preparing",
          "description": "Chunking/PreparedDocument.",
          "type": "string"
        },
        {
          "const": "embedding",
          "description": "Embedding provider/batch.",
          "type": "string"
        },
        {
          "const": "upserting",
          "description": "VectorStore writes.",
          "type": "string"
        },
        {
          "const": "publishing",
          "description": "Generation publish.",
          "type": "string"
        },
        {
          "const": "cleaning",
          "description": "Cleanup/prune/dedupe.",
          "type": "string"
        },
        {
          "const": "retrieving",
          "description": "Query/retrieve context.",
          "type": "string"
        },
        {
          "const": "synthesizing",
          "description": "LLM synthesis.",
          "type": "string"
        },
        {
          "const": "observing",
          "description": "Progress/log/status emit.",
          "type": "string"
        }
      ]
    },
    "ApiError_ErrorVisibility": {
      "description": "Where a context entry (or error) may be surfaced.\n\nFrom the \"visibility\" field in the error shape: `public`, `internal`,\n`sensitive`.",
      "oneOf": [
        {
          "const": "public",
          "description": "Safe to render to any caller, including remote/unauthenticated.",
          "type": "string"
        },
        {
          "const": "internal",
          "description": "Internal diagnostics; render only to internal/admin surfaces.",
          "type": "string"
        },
        {
          "const": "sensitive",
          "description": "Sensitive/secret-adjacent; never render raw, redaction required.",
          "type": "string"
        }
      ]
    },
    "ResolvedSource": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "authority": {
          "$ref": "#/$defs/ResolvedSource_AuthorityLevel"
        },
        "available_scopes": {
          "items": {
            "$ref": "#/$defs/ResolvedSource_SourceScope"
          },
          "type": "array"
        },
        "candidate_adapters": {
          "items": {
            "$ref": "#/$defs/ResolvedSource_AdapterCandidate"
          },
          "type": "array"
        },
        "canonical_uri": {
          "type": "string"
        },
        "confidence": {
          "format": "float",
          "type": "number"
        },
        "default_scope": {
          "$ref": "#/$defs/ResolvedSource_SourceScope"
        },
        "display_name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "requested_uri": {
          "type": "string"
        },
        "source_id": {
          "$ref": "#/$defs/ResolvedSource_SourceId"
        },
        "source_kind": {
          "$ref": "#/$defs/ResolvedSource_SourceKind"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/ResolvedSource_SourceWarning"
          },
          "type": "array"
        }
      },
      "required": [
        "requested_uri",
        "canonical_uri",
        "source_id",
        "source_kind",
        "display_name",
        "candidate_adapters",
        "default_scope",
        "available_scopes",
        "authority",
        "confidence",
        "reason",
        "warnings"
      ],
      "title": "ResolvedSource",
      "type": "object"
    },
    "ResolvedSource_AdapterCandidate": {
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "$ref": "#/$defs/ResolvedSource_AdapterRef"
        },
        "confidence": {
          "format": "float",
          "type": "number"
        },
        "reason": {
          "type": "string"
        },
        "supported_scopes": {
          "items": {
            "$ref": "#/$defs/ResolvedSource_SourceScope"
          },
          "type": "array"
        }
      },
      "required": [
        "adapter",
        "supported_scopes",
        "confidence",
        "reason"
      ],
      "type": "object"
    },
    "ResolvedSource_AdapterRef": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "ResolvedSource_AuthorityLevel": {
      "enum": [
        "official",
        "verified",
        "user_pinned",
        "inferred",
        "community",
        "mirror",
        "conflicting",
        "unknown"
      ],
      "type": "string"
    },
    "ResolvedSource_Severity": {
      "enum": [
        "debug",
        "info",
        "warning",
        "degraded",
        "failed",
        "fatal"
      ],
      "type": "string"
    },
    "ResolvedSource_SourceId": {
      "type": "string"
    },
    "ResolvedSource_SourceItemKey": {
      "type": "string"
    },
    "ResolvedSource_SourceKind": {
      "enum": [
        "web",
        "local",
        "git",
        "registry",
        "feed",
        "reddit",
        "youtube",
        "session",
        "cli_tool",
        "mcp_tool",
        "memory",
        "upload"
      ],
      "type": "string"
    },
    "ResolvedSource_SourceScope": {
      "enum": [
        "page",
        "site",
        "docs",
        "repo",
        "workspace",
        "branch",
        "org",
        "package",
        "version",
        "feed",
        "subreddit",
        "thread",
        "comment",
        "video",
        "playlist",
        "channel",
        "issue",
        "pull_request",
        "merge_request",
        "release",
        "wiki",
        "file",
        "directory",
        "map",
        "tool",
        "script",
        "api"
      ],
      "type": "string"
    },
    "ResolvedSource_SourceWarning": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ResolvedSource_Severity"
        },
        "source_item_key": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolvedSource_SourceItemKey"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "code",
        "severity",
        "message",
        "retryable"
      ],
      "type": "object"
    },
    "SourceRequest": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": [
            "string",
            "null"
          ]
        },
        "authority_hint": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceRequest_AuthorityHint"
            },
            {
              "type": "null"
            }
          ]
        },
        "collection": {
          "type": [
            "string",
            "null"
          ]
        },
        "embed": {
          "default": true,
          "type": "boolean"
        },
        "execution": {
          "$ref": "#/$defs/SourceRequest_ExecutionPolicy",
          "default": {
            "detached": false,
            "heartbeat_interval_secs": 5,
            "mode": "background",
            "priority": "normal"
          }
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "intent": {
          "$ref": "#/$defs/SourceRequest_SourceIntent",
          "default": "acquire"
        },
        "limits": {
          "$ref": "#/$defs/SourceRequest_SourceLimits",
          "default": {}
        },
        "metadata": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "options": {
          "$ref": "#/$defs/SourceRequest_AdapterOptions",
          "default": {
            "values": {}
          }
        },
        "output": {
          "$ref": "#/$defs/SourceRequest_OutputPolicy",
          "default": {
            "artifact_mode": "on_large_output",
            "include_progress": false,
            "inline_limit_bytes": 65536,
            "json": false,
            "response_mode": "auto"
          }
        },
        "refresh": {
          "$ref": "#/$defs/SourceRequest_SourceRefreshPolicy",
          "default": "if_stale"
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceRequest_SourceScope"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "type": "string"
        },
        "watch": {
          "$ref": "#/$defs/SourceRequest_SourceWatchPolicy",
          "default": "disabled"
        }
      },
      "required": [
        "source"
      ],
      "title": "SourceRequest",
      "type": "object"
    },
    "SourceRequest_AdapterOptions": {
      "additionalProperties": false,
      "properties": {
        "values": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "values"
      ],
      "type": "object"
    },
    "SourceRequest_ArtifactMode": {
      "enum": [
        "none",
        "on_large_output",
        "always"
      ],
      "type": "string"
    },
    "SourceRequest_AuthorityEvidence": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "format": "float",
          "type": "number"
        },
        "evidence_kind": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "evidence_kind",
        "value",
        "confidence"
      ],
      "type": "object"
    },
    "SourceRequest_AuthorityHint": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "$ref": "#/$defs/SourceRequest_AuthorityLevel"
        },
        "canonical_uri": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/SourceRequest_AuthorityEvidence"
          },
          "type": "array"
        }
      },
      "required": [
        "authority",
        "evidence"
      ],
      "type": "object"
    },
    "SourceRequest_AuthorityLevel": {
      "enum": [
        "official",
        "verified",
        "user_pinned",
        "inferred",
        "community",
        "mirror",
        "conflicting",
        "unknown"
      ],
      "type": "string"
    },
    "SourceRequest_ExecutionMode": {
      "enum": [
        "foreground",
        "background",
        "wait"
      ],
      "type": "string"
    },
    "SourceRequest_ExecutionPolicy": {
      "additionalProperties": false,
      "properties": {
        "detached": {
          "type": "boolean"
        },
        "heartbeat_interval_secs": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "mode": {
          "$ref": "#/$defs/SourceRequest_ExecutionMode"
        },
        "priority": {
          "$ref": "#/$defs/SourceRequest_JobPriority"
        },
        "wait_timeout_secs": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "mode",
        "priority",
        "detached",
        "heartbeat_interval_secs"
      ],
      "type": "object"
    },
    "SourceRequest_JobPriority": {
      "enum": [
        "interactive",
        "high",
        "normal",
        "background",
        "maintenance"
      ],
      "type": "string"
    },
    "SourceRequest_OutputPolicy": {
      "additionalProperties": false,
      "properties": {
        "artifact_mode": {
          "$ref": "#/$defs/SourceRequest_ArtifactMode"
        },
        "include_progress": {
          "type": "boolean"
        },
        "inline_limit_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "json": {
          "type": "boolean"
        },
        "response_mode": {
          "$ref": "#/$defs/SourceRequest_ResponseMode"
        }
      },
      "required": [
        "json",
        "response_mode",
        "inline_limit_bytes",
        "artifact_mode",
        "include_progress"
      ],
      "type": "object"
    },
    "SourceRequest_ResponseMode": {
      "enum": [
        "auto",
        "summary",
        "full",
        "inline",
        "artifact",
        "path",
        "job_only"
      ],
      "type": "string"
    },
    "SourceRequest_SourceIntent": {
      "enum": [
        "acquire",
        "refresh",
        "watch",
        "map"
      ],
      "type": "string"
    },
    "SourceRequest_SourceLimits": {
      "additionalProperties": false,
      "properties": {
        "max_bytes_per_item": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_chunks": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_depth": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_items": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_pages": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_total_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "provider_timeout_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SourceRequest_SourceRefreshPolicy": {
      "enum": [
        "if_stale",
        "force",
        "never"
      ],
      "type": "string"
    },
    "SourceRequest_SourceScope": {
      "enum": [
        "page",
        "site",
        "docs",
        "repo",
        "workspace",
        "branch",
        "org",
        "package",
        "version",
        "feed",
        "subreddit",
        "thread",
        "comment",
        "video",
        "playlist",
        "channel",
        "issue",
        "pull_request",
        "merge_request",
        "release",
        "wiki",
        "file",
        "directory",
        "map",
        "tool",
        "script",
        "api"
      ],
      "type": "string"
    },
    "SourceRequest_SourceWatchPolicy": {
      "enum": [
        "disabled",
        "ensure",
        "enabled"
      ],
      "type": "string"
    },
    "SourceResult": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "$ref": "#/$defs/SourceResult_AdapterRef"
        },
        "artifacts": {
          "items": {
            "$ref": "#/$defs/SourceResult_ArtifactRef"
          },
          "type": "array"
        },
        "canonical_uri": {
          "type": "string"
        },
        "counts": {
          "$ref": "#/$defs/SourceResult_SourceCounts"
        },
        "errors": {
          "items": {
            "$ref": "#/$defs/SourceResult_SourceError"
          },
          "type": "array"
        },
        "graph": {
          "$ref": "#/$defs/SourceResult_GraphWriteSummary"
        },
        "inline": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceResult_InlineSourceResult"
            },
            {
              "type": "null"
            }
          ]
        },
        "job": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceResult_JobDescriptor"
            },
            {
              "type": "null"
            }
          ]
        },
        "job_id": {
          "$ref": "#/$defs/SourceResult_JobId"
        },
        "ledger": {
          "$ref": "#/$defs/SourceResult_LedgerSummary"
        },
        "scope": {
          "$ref": "#/$defs/SourceResult_SourceScope"
        },
        "source_id": {
          "$ref": "#/$defs/SourceResult_SourceId"
        },
        "source_kind": {
          "$ref": "#/$defs/SourceResult_SourceKind"
        },
        "status": {
          "$ref": "#/$defs/SourceResult_LifecycleStatus"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/SourceResult_SourceWarning"
          },
          "type": "array"
        },
        "watch": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceResult_WatchResult"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "job_id",
        "source_id",
        "canonical_uri",
        "source_kind",
        "adapter",
        "scope",
        "status",
        "ledger",
        "graph",
        "counts",
        "warnings",
        "artifacts",
        "errors"
      ],
      "title": "SourceResult",
      "type": "object"
    },
    "SourceResult_AdapterRef": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "SourceResult_ArtifactId": {
      "type": "string"
    },
    "SourceResult_ArtifactKind": {
      "enum": [
        "raw_content",
        "normalized_content",
        "manifest",
        "report",
        "screenshot",
        "warc",
        "provider_trace"
      ],
      "type": "string"
    },
    "SourceResult_ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/SourceResult_ArtifactId"
        },
        "artifact_kind": {
          "$ref": "#/$defs/SourceResult_ArtifactKind"
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
