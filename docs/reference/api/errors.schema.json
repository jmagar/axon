{
  "$defs": {
    "ApiError": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "The shared, transport-neutral error shape.\n\nEvery crate reports failures as an `ApiError` so CLI, REST, MCP, jobs, logs,\nand progress streams render one consistent structure.",
      "properties": {
        "chunk_id": {
          "description": "Chunk id.",
          "type": [
            "string",
            "null"
          ]
        },
        "code": {
          "$ref": "#/$defs/ApiError_ErrorCode",
          "description": "Stable machine code (e.g. `provider.unavailable`)."
        },
        "cooldown_until": {
          "description": "Provider/job cooling timestamp.",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "details": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Redacted structured context (safe key/value pairs only).",
          "type": "object"
        },
        "document_id": {
          "description": "Document id.",
          "type": [
            "string",
            "null"
          ]
        },
        "job_id": {
          "description": "Job correlation id.",
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "description": "Redacted human-readable message.",
          "type": "string"
        },
        "provider_id": {
          "description": "Provider that failed.",
          "type": [
            "string",
            "null"
          ]
        },
        "retry_after_ms": {
          "description": "Suggested retry delay, in milliseconds.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "retryable": {
          "description": "Whether retry may succeed.",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ApiError_ErrorSeverity",
          "description": "Severity classification."
        },
        "source_id": {
          "description": "Source id.",
          "type": [
            "string",
            "null"
          ]
        },
        "source_item_key": {
          "description": "Item/file/page key.",
          "type": [
            "string",
            "null"
          ]
        },
        "stage": {
          "$ref": "#/$defs/ApiError_ErrorStage",
          "description": "Pipeline/transport stage."
        },
        "visibility": {
          "$ref": "#/$defs/ApiError_ErrorVisibility",
          "description": "Where this error may be surfaced."
        }
      },
      "required": [
        "code",
        "message",
        "stage",
        "retryable",
        "severity",
        "visibility",
        "details"
      ],
      "title": "ApiError",
      "type": "object"
    },
    "ApiError_ErrorCode": {
      "description": "A stable, machine-readable error code (e.g. `provider.unavailable`).",
      "type": "string"
    },
    "ApiError_ErrorSeverity": {
      "description": "How severe an error is and whether it terminates the item/job.",
      "oneOf": [
        {
          "const": "info",
          "description": "Informational event; not terminal.",
          "type": "string"
        },
        {
          "const": "warning",
          "description": "Non-fatal issue, full behavior preserved; not terminal.",
          "type": "string"
        },
        {
          "const": "degraded",
          "description": "Behavior reduced but acceptable by policy; may or may not be terminal.",
          "type": "string"
        },
        {
          "const": "failed",
          "description": "Required work failed; terminal for the affected item/job.",
          "type": "string"
        },
        {
          "const": "fatal",
          "description": "Cannot continue safely; terminal.",
          "type": "string"
        }
      ]
    },
    "ApiError_ErrorStage": {
      "description": "Pipeline/transport stage an error is attributed to.",
      "oneOf": [
        {
          "const": "parsing",
          "description": "CLI/MCP/REST request parse, removed command/action.",
          "type": "string"
        },
        {
          "const": "validation",
          "description": "Missing fields, bad types, unsupported flags.",
          "type": "string"
        },
        {
          "const": "resolving",
          "description": "Source resolution, canonical URI, authority.",
          "type": "string"
        },
        {
          "const": "routing",
          "description": "Adapter/scope/provider selection.",
          "type": "string"
        },
        {
          "const": "authorizing",
          "description": "Auth, credentials, execution policy.",
          "type": "string"
        },
        {
          "const": "planning",
          "description": "Source plan, prune plan.",
          "type": "string"
        },
        {
          "const": "leasing",
          "description": "Job/watch/source lease.",
          "type": "string"
        },
        {
          "const": "discovering",
          "description": "Manifest/map discovery.",
          "type": "string"
        },
        {
          "const": "diffing",
          "description": "Manifest diff.",
          "type": "string"
        },
        {
          "const": "fetching",
          "description": "HTTP/git/package/local/MCP/CLI fetch.",
          "type": "string"
        },
        {
          "const": "rendering",
          "description": "Browser/CDP/render provider.",
          "type": "string"
        },
        {
          "const": "enriching",
          "description": "Enrichment (metadata/classification/summary/extraction/authority).",
          "type": "string"
        },
        {
          "const": "normalizing",
          "description": "SourceDocument creation.",
          "type": "string"
        },
        {
          "const": "parsing_content",
          "description": "Parser facts/chunk parser (serialized as `parsing_content`).",
          "type": "string"
        },
        {
          "const": "graphing",
          "description": "Graph writes/merge/conflict.",
          "type": "string"
        },
        {
          "const": "preparing",
          "description": "Chunking/PreparedDocument.",
          "type": "string"
        },
        {
          "const": "batching",
          "description": "Batch assembly for embedding/vectorizing.",
          "type": "string"
        },
        {
          "const": "embedding",
          "description": "Embedding provider/batch.",
          "type": "string"
        },
        {
          "const": "vectorizing",
          "description": "Vector point construction/payload build.",
          "type": "string"
        },
        {
          "const": "upserting",
          "description": "VectorStore writes.",
          "type": "string"
        },
        {
          "const": "publishing",
          "description": "Generation publish.",
          "type": "string"
        },
        {
          "const": "cleaning",
          "description": "Cleanup/prune/dedupe.",
          "type": "string"
        },
        {
          "const": "retrieving",
          "description": "Query/retrieve context.",
          "type": "string"
        },
        {
          "const": "synthesizing",
          "description": "LLM synthesis.",
          "type": "string"
        },
        {
          "const": "evaluating",
          "description": "RAG/evaluation scoring.",
          "type": "string"
        },
        {
          "const": "observing",
          "description": "Progress/log/status emit.",
          "type": "string"
        },
        {
          "const": "storage",
          "description": "Storage boundary (ledger/artifact/job store), phase-contextual.",
          "type": "string"
        },
        {
          "const": "provider",
          "description": "Provider boundary (embedding/llm/render/search), phase-contextual.",
          "type": "string"
        },
        {
          "const": "transport",
          "description": "Transport boundary (CLI/REST/MCP dispatch), phase-contextual.",
          "type": "string"
        },
        {
          "const": "internal",
          "description": "Internal/unclassified failure within the active operation phase.",
          "type": "string"
        }
      ]
    },
    "ApiError_ErrorVisibility": {
      "description": "Where a context entry (or error) may be surfaced.\n\nFrom the \"visibility\" field in the error shape: `public`, `internal`,\n`sensitive`.",
      "oneOf": [
        {
          "const": "public",
          "description": "Safe to render to any caller, including remote/unauthenticated.",
          "type": "string"
        },
        {
          "const": "internal",
          "description": "Internal diagnostics; render only to internal/admin surfaces.",
          "type": "string"
        },
        {
          "const": "sensitive",
          "description": "Sensitive/secret-adjacent; never render raw, redaction required.",
          "type": "string"
        }
      ]
    },
    "DegradationPolicy": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Whether an error path can degrade rather than fail, and why.",
      "properties": {
        "degradable": {
          "description": "Whether the pipeline may degrade (continue with reduced behavior).",
          "type": "boolean"
        },
        "reason": {
          "description": "Human-readable reason for the degradation decision.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "degradable"
      ],
      "title": "DegradationPolicy",
      "type": "object"
    },
    "ErrorCode": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "A stable, machine-readable error code (e.g. `provider.unavailable`).",
      "title": "ErrorCode",
      "type": "string"
    },
    "ErrorContext": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": {
        "$ref": "#/$defs/ErrorContext_ErrorContextEntry"
      },
      "description": "Redacted key/value error details with per-entry visibility + secret hints.",
      "title": "ErrorContext",
      "type": "object"
    },
    "ErrorContext_ErrorContextEntry": {
      "description": "A single redaction-aware context detail.\n\nThe `value` is a redaction *hint*, not necessarily a redacted value — the\nrenderer decides what to emit based on `visibility` and `secret_class`. When\n`visibility` is not `Public`, callers must not surface `value` to public\noutput.",
      "properties": {
        "secret_class": {
          "description": "Optional secret-class hint (e.g. `api_key`, `local_path`, `token`).\n\nA hint only — `axon-error` does not classify or redact; downstream\ncrates use it to pick the correct redaction policy.",
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "description": "Detail value (a redaction hint; may be a placeholder for sensitive data).",
          "type": "string"
        },
        "visibility": {
          "$ref": "#/$defs/ErrorContext_ErrorVisibility",
          "description": "Where this entry may be surfaced."
        }
      },
      "required": [
        "value",
        "visibility"
      ],
      "type": "object"
    },
    "ErrorContext_ErrorVisibility": {
      "description": "Where a context entry (or error) may be surfaced.\n\nFrom the \"visibility\" field in the error shape: `public`, `internal`,\n`sensitive`.",
      "oneOf": [
        {
          "const": "public",
          "description": "Safe to render to any caller, including remote/unauthenticated.",
          "type": "string"
        },
        {
          "const": "internal",
          "description": "Internal diagnostics; render only to internal/admin surfaces.",
          "type": "string"
        },
        {
          "const": "sensitive",
          "description": "Sensitive/secret-adjacent; never render raw, redaction required.",
          "type": "string"
        }
      ]
    },
    "ErrorEnvelope": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "string"
        },
        "error": {
          "$ref": "#/$defs/ErrorEnvelope_ApiError"
        },
        "ok": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "trace": {
          "$ref": "#/$defs/ErrorEnvelope_TraceContext"
        }
      },
      "required": [
        "ok",
        "contract_version",
        "error",
        "request_id",
        "trace"
      ],
      "title": "ErrorEnvelope",
      "type": "object"
    },
