    },
    "JobHeartbeat": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "counts": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobHeartbeat_StageCounts"
            },
            {
              "type": "null"
            }
          ]
        },
        "heartbeat_at": {
          "type": "string"
        },
        "job_id": {
          "$ref": "#/$defs/JobHeartbeat_JobId"
        },
        "last_event_sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "phase": {
          "$ref": "#/$defs/JobHeartbeat_PipelinePhase"
        },
        "provider_reservations": {
          "items": {
            "$ref": "#/$defs/JobHeartbeat_ProviderReservationSnapshot"
          },
          "type": "array"
        },
        "stage_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobHeartbeat_StageId"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/JobHeartbeat_LifecycleStatus"
        },
        "worker_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "job_id",
        "phase",
        "status",
        "heartbeat_at"
      ],
      "title": "JobHeartbeat",
      "type": "object"
    },
    "JobHeartbeat_JobId": {
      "format": "uuid",
      "type": "string"
    },
    "JobHeartbeat_JobPriority": {
      "enum": [
        "interactive",
        "high",
        "normal",
        "background",
        "maintenance"
      ],
      "type": "string"
    },
    "JobHeartbeat_LifecycleStatus": {
      "enum": [
        "queued",
        "pending",
        "running",
        "waiting",
        "blocked",
        "canceling",
        "completed",
        "completed_degraded",
        "failed",
        "canceled",
        "expired",
        "skipped"
      ],
      "type": "string"
    },
    "JobHeartbeat_PipelinePhase": {
      "enum": [
        "queued",
        "requested",
        "resolving",
        "routing",
        "authorizing",
        "planning",
        "leasing",
        "discovering",
        "diffing",
        "fetching",
        "rendering",
        "enriching",
        "normalizing",
        "parsing",
        "graphing",
        "preparing",
        "batching",
        "embedding",
        "vectorizing",
        "upserting",
        "retrieving",
        "synthesizing",
        "evaluating",
        "publishing",
        "cleaning",
        "complete",
        "canceled"
      ],
      "type": "string"
    },
    "JobHeartbeat_ProviderCoolingSnapshot": {
      "additionalProperties": false,
      "properties": {
        "degraded": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "retry_after": {
          "type": [
            "string",
            "null"
          ]
        },
        "started_at": {
          "type": "string"
        }
      },
      "required": [
        "reason",
        "started_at",
        "degraded"
      ],
      "type": "object"
    },
    "JobHeartbeat_ProviderId": {
      "type": "string"
    },
    "JobHeartbeat_ProviderKind": {
      "enum": [
        "llm",
        "embedding",
        "vector",
        "search",
        "fetch",
        "render",
        "network_capture",
        "artifact",
        "ledger",
        "graph",
        "memory",
        "job",
        "watch",
        "config",
        "credential",
        "cache",
        "security",
        "rate_limiter",
        "health_probe"
      ],
      "type": "string"
    },
    "JobHeartbeat_ProviderReservationSnapshot": {
      "additionalProperties": false,
      "properties": {
        "acquired_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "cooling": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobHeartbeat_ProviderCoolingSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "granted_units": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "priority": {
          "$ref": "#/$defs/JobHeartbeat_JobPriority"
        },
        "provider_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobHeartbeat_ProviderId"
            },
            {
              "type": "null"
            }
          ]
        },
        "provider_kind": {
          "$ref": "#/$defs/JobHeartbeat_ProviderKind"
        },
        "queue_depth": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "requested_units": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "reservation_id": {
          "$ref": "#/$defs/JobHeartbeat_ReservationId"
        },
        "status": {
          "$ref": "#/$defs/JobHeartbeat_LifecycleStatus"
        }
      },
      "required": [
        "reservation_id",
        "provider_kind",
        "priority",
        "requested_units",
        "granted_units",
        "status"
      ],
      "type": "object"
    },
    "JobHeartbeat_ReservationId": {
      "type": "string"
    },
    "JobHeartbeat_StageCounts": {
      "additionalProperties": false,
      "properties": {
        "bytes_done": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "bytes_total": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "chunks_done": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "chunks_total": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "documents_done": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "documents_total": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "items_done": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "items_total": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "items_done",
        "documents_done",
        "chunks_done",
        "bytes_done"
      ],
      "type": "object"
    },
    "JobHeartbeat_StageId": {
      "format": "uuid",
      "type": "string"
    },
    "ProgressCurrent": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": [
            "string",
