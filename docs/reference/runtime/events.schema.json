{
  "$defs": {
    "JobEvent": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "details": {
          "additionalProperties": true,
          "type": "object"
        },
        "event_id": {
          "type": "string"
        },
        "job_id": {
          "$ref": "#/$defs/JobEvent_JobId"
        },
        "message": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/JobEvent_PipelinePhase"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/JobEvent_Severity"
        },
        "stage_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobEvent_StageId"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/JobEvent_LifecycleStatus"
        },
        "timestamp": {
          "type": "string"
        },
        "visibility": {
          "$ref": "#/$defs/JobEvent_Visibility",
          "default": "internal"
        }
      },
      "required": [
        "event_id",
        "sequence",
        "job_id",
        "phase",
        "status",
        "severity",
        "message",
        "timestamp",
        "details"
      ],
      "title": "JobEvent",
      "type": "object"
    },
    "JobEventPage": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "events": {
          "items": {
            "$ref": "#/$defs/JobEventPage_JobEvent"
          },
          "type": "array"
        },
        "last_sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "limit": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "next_cursor": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "events",
        "limit"
      ],
      "title": "JobEventPage",
      "type": "object"
    },
    "JobEventPage_JobEvent": {
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "details": {
          "additionalProperties": true,
          "type": "object"
        },
        "event_id": {
          "type": "string"
        },
        "job_id": {
          "$ref": "#/$defs/JobEventPage_JobId"
        },
        "message": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/JobEventPage_PipelinePhase"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/JobEventPage_Severity"
        },
        "stage_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/JobEventPage_StageId"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/JobEventPage_LifecycleStatus"
        },
        "timestamp": {
          "type": "string"
        },
        "visibility": {
          "$ref": "#/$defs/JobEventPage_Visibility",
          "default": "internal"
        }
      },
      "required": [
        "event_id",
        "sequence",
        "job_id",
        "phase",
        "status",
        "severity",
        "message",
        "timestamp",
        "details"
      ],
      "type": "object"
    },
    "JobEventPage_JobId": {
      "format": "uuid",
      "type": "string"
    },
    "JobEventPage_LifecycleStatus": {
      "enum": [
        "queued",
        "pending",
        "running",
        "waiting",
        "blocked",
        "canceling",
        "completed",
        "completed_degraded",
        "failed",
        "canceled",
        "expired",
        "skipped"
      ],
      "type": "string"
    },
    "JobEventPage_PipelinePhase": {
      "enum": [
        "queued",
        "requested",
        "resolving",
        "routing",
        "authorizing",
        "planning",
        "leasing",
        "discovering",
        "diffing",
        "fetching",
        "rendering",
        "enriching",
        "normalizing",
        "parsing",
        "graphing",
        "preparing",
        "batching",
        "embedding",
        "vectorizing",
        "upserting",
        "retrieving",
        "synthesizing",
        "evaluating",
        "publishing",
        "cleaning",
        "complete",
        "canceled"
      ],
      "type": "string"
    },
    "JobEventPage_Severity": {
      "enum": [
        "debug",
        "info",
        "warning",
        "degraded",
        "failed",
        "fatal"
      ],
      "type": "string"
    },
    "JobEventPage_StageId": {
      "format": "uuid",
      "type": "string"
    },
    "JobEventPage_Visibility": {
      "enum": [
        "public",
        "internal",
        "sensitive",
        "redacted",
        "derived"
      ],
      "type": "string"
    },
    "JobEvent_JobId": {
      "format": "uuid",
      "type": "string"
    },
    "JobEvent_LifecycleStatus": {
      "enum": [
        "queued",
        "pending",
        "running",
        "waiting",
        "blocked",
        "canceling",
        "completed",
        "completed_degraded",
        "failed",
        "canceled",
        "expired",
        "skipped"
      ],
      "type": "string"
    },
    "JobEvent_PipelinePhase": {
      "enum": [
        "queued",
        "requested",
        "resolving",
        "routing",
        "authorizing",
        "planning",
        "leasing",
        "discovering",
        "diffing",
        "fetching",
        "rendering",
        "enriching",
        "normalizing",
        "parsing",
        "graphing",
        "preparing",
        "batching",
        "embedding",
        "vectorizing",
        "upserting",
        "retrieving",
        "synthesizing",
        "evaluating",
        "publishing",
        "cleaning",
        "complete",
        "canceled"
      ],
      "type": "string"
    },
    "JobEvent_Severity": {
      "enum": [
        "debug",
        "info",
        "warning",
        "degraded",
        "failed",
        "fatal"
      ],
      "type": "string"
    },
    "JobEvent_StageId": {
      "format": "uuid",
