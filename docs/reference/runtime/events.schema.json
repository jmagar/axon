            }
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProgressCurrent_ProviderId"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_item_key": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProgressCurrent_SourceItemKey"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "title": "ProgressCurrent",
      "type": "object"
    },
    "ProgressCurrent_ChunkId": {
      "type": "string"
    },
    "ProgressCurrent_DocumentId": {
      "type": "string"
    },
    "ProgressCurrent_ProviderId": {
      "type": "string"
    },
    "ProgressCurrent_SourceItemKey": {
      "type": "string"
    },
    "ProgressTiming": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "elapsed_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "eta_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "started_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "required": [
        "started_at",
        "updated_at",
        "elapsed_ms"
      ],
      "title": "ProgressTiming",
      "type": "object"
    },
    "SourceProgressEvent": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_AdapterRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "attempt": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "batch_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_BatchId"
            },
            {
              "type": "null"
            }
          ]
        },
        "canonical_uri": {
          "type": [
            "string",
            "null"
          ]
        },
        "checkpoint_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_CheckpointId"
            },
            {
              "type": "null"
            }
          ]
        },
        "counts": {
          "$ref": "#/$defs/SourceProgressEvent_StageCounts"
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_ProgressCurrent"
            },
            {
              "type": "null"
            }
          ]
        },
        "dedupe_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_ApiError"
            },
            {
              "type": "null"
            }
          ]
        },
        "event_id": {
          "type": "string"
        },
        "generation": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_SourceGenerationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "job_id": {
          "$ref": "#/$defs/SourceProgressEvent_JobId"
        },
        "message": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/SourceProgressEvent_PipelinePhase"
        },
        "reservation_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_ReservationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_RetryState"
            },
            {
              "type": "null"
            }
          ]
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_SourceScope"
            },
            {
              "type": "null"
            }
          ]
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/SourceProgressEvent_Severity"
        },
        "source_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_SourceId"
            },
            {
              "type": "null"
            }
          ]
        },
        "stage_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_StageId"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/SourceProgressEvent_LifecycleStatus"
        },
        "throughput": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_ProgressThroughput"
            },
            {
              "type": "null"
            }
          ]
        },
        "timestamp": {
          "type": "string"
        },
        "timing": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_ProgressTiming"
            },
            {
              "type": "null"
            }
          ]
        },
        "visibility": {
          "$ref": "#/$defs/SourceProgressEvent_Visibility"
        },
        "warning": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProgressEvent_SourceWarning"
            },
            {
              "type": "null"
            }
          ]
        }
      },
