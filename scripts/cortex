#!/usr/bin/env bash
set -euo pipefail

REPO="/home/jmagar/workspace/axon_rust"
CLI_ENV="$REPO/.env"

if [[ -f "$CLI_ENV" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CLI_ENV"
  set +a
fi

BIN=""
for candidate in \
  "$REPO/target/debug/cortex" \
  "$REPO/target/release/cortex" \
  "/home/jmagar/workspace/spider/target/debug/examples/axon_cli_rust"
do
  if [[ -x "$candidate" ]]; then
    BIN="$candidate"
    break
  fi
done

if [[ -z "$BIN" ]]; then
  cargo build -q --manifest-path "$REPO/Cargo.toml" --bin cortex
  BIN="$REPO/target/debug/cortex"
fi

exec "$BIN" "$@"
