#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "usage: cargo-rustc-wrapper <rustc> [rustc-args...]" >&2
  exit 2
fi

rustc="$1"
shift

crate_name=""
crate_type=""
out=""
out_dir=""
extra_filename=""
is_test=0
args=("$@")

i=0
while [ "$i" -lt "${#args[@]}" ]; do
  arg="${args[$i]}"
  case "$arg" in
    --crate-name)
      i=$((i + 1))
      crate_name="${args[$i]:-}"
      ;;
    --crate-name=*)
      crate_name="${arg#--crate-name=}"
      ;;
    --crate-type)
      i=$((i + 1))
      crate_type="${args[$i]:-}"
      ;;
    --crate-type=*)
      crate_type="${arg#--crate-type=}"
      ;;
    -o)
      i=$((i + 1))
      out="${args[$i]:-}"
      ;;
    --out-dir)
      i=$((i + 1))
      out_dir="${args[$i]:-}"
      ;;
    -C)
      i=$((i + 1))
      codegen_opt="${args[$i]:-}"
      case "$codegen_opt" in
        extra-filename=*) extra_filename="${codegen_opt#extra-filename=}" ;;
      esac
      ;;
    -Cextra-filename=*)
      extra_filename="${arg#-Cextra-filename=}"
      ;;
    --test)
      is_test=1
      ;;
  esac
  i=$((i + 1))
done

if [ -n "${AXON_RUSTC_WRAPPER_DELEGATE:-}" ]; then
  delegate=("$AXON_RUSTC_WRAPPER_DELEGATE" "$rustc")
elif [ "${AXON_RUSTC_WRAPPER_NO_SCCACHE:-0}" != "1" ] \
  && command -v sccache >/dev/null 2>&1 \
  && sccache --version >/dev/null 2>&1; then
  delegate=(sccache "$rustc")
else
  delegate=("$rustc")
fi

"${delegate[@]}" "${args[@]}"

if [ -z "$out" ] && [ -n "$out_dir" ] && [ -n "$extra_filename" ]; then
  out="$out_dir/$crate_name$extra_filename"
fi

if [ "$crate_name" != "axon" ] || [ "$crate_type" != "bin" ] || [ "$is_test" -eq 1 ] || [ -z "$out" ] || [ ! -x "$out" ]; then
  exit 0
fi

case "$out" in
  target/debug/deps/axon-*|target/release/deps/axon-*|*/target/debug/deps/axon-*|*/target/release/deps/axon-*) ;;
  *) exit 0 ;;
esac

local_bin="${AXON_RUSTC_WRAPPER_LOCAL_BIN:-$HOME/.local/bin/axon}"

mkdir -p "$(dirname "$local_bin")"
cp -f "$out" "$local_bin"
