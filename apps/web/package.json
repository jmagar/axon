{
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  },
  "name": "@axon/admin-panel",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "tsc --noEmit",
    "openapi:check": "cd ../.. && cargo xtask check-openapi-drift",
    "openapi:export": "mkdir -p openapi && cargo run --quiet --manifest-path ../../Cargo.toml --bin axon-openapi > openapi/axon.json",
    "openapi:generate": "npm run openapi:export && npm run openapi:types",
    "openapi:types": "node scripts/generate-openapi-types.mjs openapi/axon.json src/api/generated/axon-api.ts",
    "test": "vitest run"
  },
  "version": "6.2.2"
}
