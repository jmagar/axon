<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / device-transfer exclusion rules. We already set allowBackup=false on
    <application>, but cloud-backup and device-transfer also flow through these
    rules on Android 12+. Explicitly exclude:
      - axon_secrets       — bearer token (EncryptedTokenStore)
      - axon_headers       — user-configured HTTP headers (EncryptedHeadersStore)
      - settings DataStore — server URL, collection, and any residual legacy
        plaintext token that survived a mid-migration crash
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="axon_secrets.xml"/>
        <exclude domain="sharedpref" path="axon_headers.xml"/>
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
        <exclude domain="file" path="datastore/mode_options.preferences_pb"/>
        <exclude domain="file" path="datastore/recent_jobs.preferences_pb"/>
        <exclude domain="database" path="axon.db"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="axon_secrets.xml"/>
        <exclude domain="sharedpref" path="axon_headers.xml"/>
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
        <exclude domain="file" path="datastore/mode_options.preferences_pb"/>
        <exclude domain="file" path="datastore/recent_jobs.preferences_pb"/>
        <exclude domain="database" path="axon.db"/>
    </device-transfer>
</data-extraction-rules>
