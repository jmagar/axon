{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axon Palette",
  "version": "0.1.0",
  "identifier": "tv.tootie.axon.palette",
  "build": {
    "beforeDevCommand": "npm run vite:build",
    "beforeBuildCommand": "npm run vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Axon Palette",
        "label": "main",
        "width": 1040,
        "height": 620,
        "minWidth": 720,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
