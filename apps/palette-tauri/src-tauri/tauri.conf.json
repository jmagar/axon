{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axon Palette",
  "version": "4.5.0",
  "identifier": "tv.tootie.axon.palette",
  "build": {
    "beforeDevCommand": "npm run vite:build",
    "beforeBuildCommand": "npm run vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Axon Palette",
        "label": "main",
        "width": 1040,
        "height": 620,
        "minWidth": 720,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* http://100.88.16.79:* https://axon.tootie.tv"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
