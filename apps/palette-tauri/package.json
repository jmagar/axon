{
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "3.23.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "openapi-typescript": "^7.13.0",
    "shadcn": "^4.11.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  },
  "name": "axon-palette-tauri",
  "private": true,
  "scripts": {
    "build": "tauri build && node scripts/copy-artifacts.mjs",
    "check:api": "cd ../.. && cargo xtask check-openapi-drift",
    "coverage": "vitest run --coverage",
    "dev": "tauri dev",
    "fixture:operation-results": "vite --host 127.0.0.1 --open '/?fixture=operation-results'",
    "format": "biome format --write . && biome check --write .",
    "generate:api": "node scripts/generate-api.mjs",
    "lint": "biome lint .",
    "preview": "vite preview",
    "qa:ask-stream": "python scripts/qa-ask-stream-transition.py",
    "qa:switcher": "labby gateway code exec --file scripts/qa-switcher-open.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm install --frozen-lockfile && pnpm lint && pnpm test && pnpm check:api && pnpm typecheck && pnpm vite:build",
    "vite:build": "vite build",
    "vite:dev": "vite --host 127.0.0.1"
  },
  "type": "module",
  "version": "5.11.2"
}
