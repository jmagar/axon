# Axon env: secrets, URLs, auth/bootstrap, compose interpolation only.
# Tuning knobs (AXON_ASK_*, AXON_HYBRID_*, TEI_MAX_*, etc.) live in ~/.axon/config.toml.

# ── Data + service URLs ─────────────────────────────────────────────────────
AXON_DATA_DIR=
AXON_HOME=
QDRANT_URL=http://127.0.0.1:53333
TEI_URL=http://127.0.0.1:52000
AXON_CHROME_REMOTE_URL=http://127.0.0.1:6000
AXON_COLLECTION=axon

# ── MCP HTTP server ─────────────────────────────────────────────────────────
AXON_MCP_HTTP_HOST=127.0.0.1
AXON_MCP_HTTP_PORT=8001
# Local bearer setup generates this value; fill manually only when not using setup init.
AXON_MCP_HTTP_TOKEN=
AXON_MCP_AUTH_MODE=bearer
# Required only when AXON_MCP_AUTH_MODE=oauth.
AXON_MCP_PUBLIC_URL=
AXON_MCP_GOOGLE_CLIENT_ID=
AXON_MCP_GOOGLE_CLIENT_SECRET=
AXON_MCP_AUTH_ADMIN_EMAIL=
AXON_MCP_AUTH_ALLOWED_REDIRECT_URIS=
AXON_MCP_ALLOWED_ORIGINS=

# ── Ingest credentials ──────────────────────────────────────────────────────
TAVILY_API_KEY=
# Self-hosted SearXNG instance for `search` and `research` (JSON format must be
# enabled in its settings.yml). When set, both use SearXNG instead of Tavily.
AXON_SEARXNG_URL=
# research synthesizes over full page content by default; set false for
# snippet-only/fast. Default: true.
AXON_RESEARCH_FULL_CONTENT=
GITHUB_TOKEN=
GITLAB_TOKEN=
GITEA_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
HF_TOKEN=

# ── LLM runtime ─────────────────────────────────────────────────────────────
# Default: Gemini headless. For llama.cpp's OpenAI-compatible server, set:
# AXON_LLM_BACKEND=openai-compat
# For Codex CLI app-server synthesis, set:
# AXON_LLM_BACKEND=codex-app-server
AXON_LLM_BACKEND=
# LLM completion concurrency + per-call timeout (all backends). Defaults: 4, 300.
AXON_LLM_COMPLETION_CONCURRENCY=
AXON_LLM_COMPLETION_TIMEOUT_SECS=

# OpenAI-compatible endpoint settings (llama.cpp server, LM Studio, etc.).
# Base URL is the API root; do not include /chat/completions.
AXON_OPENAI_BASE_URL=
# Synthesis model for ask / evaluate / suggest / extract / research.
# AXON_OPENAI_MODEL is kept as the legacy alias for this value.
AXON_SYNTHESIS_OPENAI_MODEL=
AXON_OPENAI_MODEL=
# Direct chat model. Empty = use the synthesis model above.
AXON_CHAT_OPENAI_MODEL=
AXON_OPENAI_API_KEY=

# Codex app-server backend settings. This is not an OpenAI-compatible HTTP
# endpoint; Axon spawns `codex app-server` per completion over stdio.
# AXON_CODEX_HOME is optional when the default Codex home has auth. The child
# uses an isolated throwaway CODEX_HOME and does not load user hooks, MCP
# servers, apps, or skills. Bare OPENAI_API_KEY is ignored by Axon config but
# may be forwarded only into this isolated Codex child as an optional auth path.
AXON_CODEX_CMD=
AXON_CODEX_COMPLETION_CONCURRENCY=
AXON_CODEX_HOME=
AXON_CODEX_MODEL=
AXON_SYNTHESIS_CODEX_MODEL=

# Gemini headless settings
# Pick one auth path:
#   - OAuth (default): leave GEMINI_API_KEY blank, ensure $HOME/.gemini exists
#   - API key: set GEMINI_API_KEY (GOOGLE_API_KEY is also accepted)
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Docker bind mount: host dir holding the OAuth credentials for the gemini CLI.
GEMINI_HOME=
# Runtime override: dir axon copies OAuth files FROM into an isolated temp HOME
# per Gemini invocation. Defaults to $HOME. Set only if Gemini creds live elsewhere.
AXON_HEADLESS_GEMINI_HOME=
# Path to the gemini binary. Defaults to PATH lookup of `gemini`.
AXON_HEADLESS_GEMINI_CMD=
# Synthesis Gemini model for ask / evaluate / suggest / extract / research.
# AXON_HEADLESS_GEMINI_MODEL is kept as the legacy alias for this value.
AXON_SYNTHESIS_HEADLESS_GEMINI_MODEL=
# Gemini model override (e.g. gemini-2.5-flash-exp). Defaults to gemini CLI's choice.
AXON_HEADLESS_GEMINI_MODEL=
# Direct chat Gemini model. Empty = use the synthesis model above.
AXON_CHAT_HEADLESS_GEMINI_MODEL=

# ── HTTP behavior ───────────────────────────────────────────────────────────
# General-purpose User-Agent for all HTTP requests (API calls, vertical extractors,
# web scraping). Falls back to a Firefox browser UA when unset.
# AXON_CHROME_USER_AGENT inherits this value when it is not set explicitly.
AXON_USER_AGENT=
# Chrome-specific User-Agent override (Spider crawl + Chrome render paths).
# Falls back to AXON_USER_AGENT, then the built-in browser default.
AXON_CHROME_USER_AGENT=

# ── Logging ─────────────────────────────────────────────────────────────────
# Full path to active log file. Rotated siblings (.1, .2, ...) live in the same dir.
# Default: $AXON_DATA_DIR/logs/axon.log
AXON_LOG_PATH=

# ── Compose interpolation (Docker only) ─────────────────────────────────────
# Qdrant runs on tootie by default to keep its large resident working set off
# the dev box. Set AXON_QDRANT_URL=http://axon-qdrant:6333 only when also
# starting the optional local axon-qdrant compose service.
AXON_QDRANT_URL=http://100.120.242.29:53333
# AXON_IMAGE — the axon server Docker image reference.
# WARNING: leaving this as `:latest` or a mutable tag means `docker compose pull`
# can silently swap chunking/embedding behavior under a stable corpus when a new
# image is published. Pin to a SHA digest to lock behavior:
#
#   AXON_IMAGE=ghcr.io/jmagar/axon@sha256:<digest>
#
# To find the current digest for a tag:
#   docker inspect --format='{{index .RepoDigests 0}}' ghcr.io/jmagar/axon:latest
#   # or: crane digest ghcr.io/jmagar/axon:latest
#
# SHA-tagged images are published alongside every main-branch push. Pin the
# digest from the release you validated, not the mutable tag itself.
AXON_IMAGE=
AXON_MCP_HTTP_PUBLISH=8001
TEI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
TEI_HTTP_PORT=52000
TEI_SERVER_MAX_CLIENT_BATCH_SIZE=96
NVIDIA_VISIBLE_DEVICES=0
CUDA_VISIBLE_DEVICES=0
