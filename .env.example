# Axon Environment Template
# Copy to ~/.axon/.env and fill in values for your environment.
#
# Auto-loaded files (in order; first successfully loaded file wins):
#   1. $AXON_ENV_FILE (if set)
#   2. ~/.axon/.env  (canonical user-level secrets, loaded automatically)
#   3. .env in the repo root (or any ancestor of CWD; development fallback only)
# dotenvy does not override process env vars that were already set.
#
# Two-layer config: service URLs and secrets live here; tuning knobs
# (search params, worker limits, TEI batch sizes) can also be set here
# via env vars OR in ~/.axon/config.toml (see config.example.toml).
# Env vars always override config.toml values.
#
# Sections:
#   REQUIRED    — axon won't work without these
#   OPTIONAL    — sensible defaults exist; override as needed
#
# Note: Docker Compose also reads TEI service config (model, concurrency,
# ports) from this file. The axon binary reads TEI_URL plus the client-side
# TEI/Qdrant tuning variables below.


# ── Core Services ─────────────────────────────────────────────────────────────
# [REQUIRED] Qdrant vector store URL. No default — must be set.
# Local dev: http://127.0.0.1:53333
QDRANT_URL=http://axon-qdrant:6333

# [REQUIRED] TEI embedding service URL. No default — must be set.
# Local dev: http://127.0.0.1:52000
TEI_URL=http://axon-tei:80


# ── Storage & Data ────────────────────────────────────────────────────────────
# [OPTIONAL] Explicit env file to load before ~/.axon/.env.
# Must point at a dotenv-compatible file.
# AXON_ENV_FILE=

# [OPTIONAL] Explicit TOML tuning file. Must point at a .toml file.
# Defaults to ~/.axon/config.toml when present.
# AXON_CONFIG_PATH=

# [OPTIONAL] Host appdata root used by Docker Compose interpolation.
# Default: ${HOME}/.axon. Keep this aligned with AXON_DATA_DIR unless you are
# intentionally relocating the entire Axon appdata tree.
# AXON_HOME=${HOME}/.axon

# [OPTIONAL] Host address/port used by Docker Compose for axon MCP HTTP.
# Default is loopback-only. Set to 0.0.0.0:8001 only when intentionally
# exposing the service beyond the host and MCP auth is configured.
# AXON_MCP_HTTP_PUBLISH=127.0.0.1:8001

# [OPTIONAL] Root directory for all axon persistent data on the host.
# Default: ~/.axon (data goes directly in ~/.axon/). Leave unset to use
# the default — only set this if you want a non-canonical location
# (e.g. a SAN mount) or have an existing ~/.local/share/axon installation.
# AXON_DATA_DIR=

# [OPTIONAL] Path to the SQLite jobs database.
# Default: $AXON_DATA_DIR/jobs.db
AXON_SQLITE_PATH=

# [OPTIONAL] Compatibility flag. SQLite/in-process jobs are always used; this
# has no behavior change beyond preserving older env files and commands.
# AXON_LITE=1


# ── LLM / Completion ──────────────────────────────────────────────────────────
# Used by LLM-backed commands: ask, evaluate, suggest, research, extract fallback.
# [OPTIONAL] OpenAI-compatible base URL for LLM completions.
OPENAI_BASE_URL=

# [OPTIONAL] API key for OPENAI_BASE_URL.
OPENAI_API_KEY=

# [OPTIONAL] Compatibility model name for older env files. Only gemini-* values
# are reused by Gemini headless; older OpenAI model names are ignored.
OPENAI_MODEL=

# ── Embedding / TEI Tuning ────────────────────────────────────────────────────
# [OPTIONAL] Max TEI embedding retry attempts after the initial request.
# Retries transport errors, 429s, and 5xx responses. Default: 5.
TEI_MAX_RETRIES=5

# [OPTIONAL] Per-attempt TEI request timeout in ms. Default: 30000.
TEI_REQUEST_TIMEOUT_MS=30000

# [OPTIONAL] Max batch size sent to TEI per request. Default: 64 (max: 128).
TEI_MAX_CLIENT_BATCH_SIZE=64

# [OPTIONAL] Process-wide concurrent in-flight TEI /embed requests (clamped 1-64). Default: 8.
AXON_TEI_MAX_CONCURRENT=8

# [OPTIONAL] Buffered Qdrant points before embed pipeline flush (clamped 128-16384). Default: 256.
AXON_QDRANT_POINT_BUFFER=256

# [OPTIONAL] Points per Qdrant upsert request (clamped 1-4096). Default: 256.
AXON_QDRANT_UPSERT_BATCH_SIZE=256


# ── Docker TEI Service ────────────────────────────────────────────────────────
# Read by docker compose for axon-tei. These are service-side settings, not
# axon client settings.
HF_TOKEN=
TEI_HTTP_PORT=52000
TEI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
TEI_MAX_CONCURRENT_REQUESTS=80
TEI_MAX_BATCH_TOKENS=163840
TEI_MAX_BATCH_REQUESTS=80
TEI_POOLING=last-token
TEI_TOKENIZATION_WORKERS=8

# [OPTIONAL] GPU selection for Docker TEI.
NVIDIA_VISIBLE_DEVICES=0
CUDA_VISIBLE_DEVICES=0


# ── Search & Ingest Credentials ───────────────────────────────────────────────
# [OPTIONAL] Tavily API key — required for `axon search` and `axon research`.
TAVILY_API_KEY=

# [OPTIONAL] GitHub personal access token — required for private repos / higher rate limits.
GITHUB_TOKEN=

# [OPTIONAL] Max GitHub issues/PRs captured during GitHub ingest. Default: 100 each.
GITHUB_MAX_ISSUES=100
GITHUB_MAX_PRS=100

# [OPTIONAL] Reddit OAuth2 client ID (https://www.reddit.com/prefs/apps).
REDDIT_CLIENT_ID=

# [OPTIONAL] Reddit OAuth2 client secret.
REDDIT_CLIENT_SECRET=


# ── Vector Search & Collection ────────────────────────────────────────────────
# [OPTIONAL] Qdrant collection for embed/query/retrieve/ask.
# WARNING: default changed from `axon` to `cortex`. Existing deployments must
# set AXON_COLLECTION=axon or run `axon migrate --from axon --to cortex`.
AXON_COLLECTION=cortex

# [OPTIONAL] Enable RRF hybrid search (BM42 sparse + dense). Default: true.
# Only effective on named-mode collections (run `axon migrate` to upgrade).
AXON_HYBRID_SEARCH=true

# [OPTIONAL] Candidates per prefetch arm before RRF fusion (clamped 10–500). Default: 100.
AXON_HYBRID_CANDIDATES=100

# [OPTIONAL] Ask-pipeline hybrid prefetch window (clamped 10–500). Default: 150.
AXON_ASK_HYBRID_CANDIDATES=150

# [OPTIONAL] HNSW ef for named-mode search (clamped 32–512). Default: 128.
AXON_HNSW_EF_SEARCH=128

# [OPTIONAL] HNSW ef for legacy unnamed-mode search (clamped 16–256). Default: 64.
AXON_HNSW_EF_SEARCH_LEGACY=64


# ── Ask / RAG Tuning ──────────────────────────────────────────────────────────
# [OPTIONAL] Max context characters passed to the LLM (clamped 20000–400000). Default: 120000.
AXON_ASK_MAX_CONTEXT_CHARS=120000

# [OPTIONAL] Max retrieval candidates per prefetch (clamped 8–300). Default: 150.
AXON_ASK_CANDIDATE_LIMIT=150

# [OPTIONAL] Concurrent document fetches during ask context build (clamped 1–16). Default: 4.
AXON_ASK_DOC_FETCH_CONCURRENCY=4

# [OPTIONAL] Max chunks per document in context (default: 192).
AXON_ASK_DOC_CHUNK_LIMIT=192

# [OPTIONAL] Max total chunks selected for LLM context (default: 10).
AXON_ASK_CHUNK_LIMIT=10

# [OPTIONAL] Max full documents included in context (default: 4).
AXON_ASK_FULL_DOCS=4

# [OPTIONAL] Backfill chunks from top documents to pad context (default: 3).
AXON_ASK_BACKFILL_CHUNKS=3

# [OPTIONAL] Minimum relevance score for candidate inclusion (default: 0.45).
AXON_ASK_MIN_RELEVANCE_SCORE=0.45

# [OPTIONAL] Boost weight for authoritative domains in reranking (clamped 0.0–0.5). Default: 0.0.
AXON_ASK_AUTHORITATIVE_BOOST=0.0

# [OPTIONAL] Comma-separated authoritative domains to boost in reranking.
# Example: platejs.org,example-docs.io
AXON_ASK_AUTHORITATIVE_DOMAINS=

# [OPTIONAL] Min unique citations for non-trivial answers (clamped 1–5). Default: 2.
AXON_ASK_MIN_CITATIONS_NONTRIVIAL=2


# ── Suggest / Discovery Tuning ────────────────────────────────────────────────
# [OPTIONAL] Domain facet count sent to the suggestion prompt (clamped 10-5000). Default: 250.
AXON_SUGGEST_BASE_URL_LIMIT=250

# [OPTIONAL] Existing indexed URLs sampled into the suggestion prompt (clamped 0-5000). Default: 500.
AXON_SUGGEST_EXISTING_URL_LIMIT=500

# [OPTIONAL] Indexed URLs scanned for duplicate filtering (clamped 100-500000). Default: 50000.
AXON_SUGGEST_INDEX_LIMIT=50000


# ── Job Workers ───────────────────────────────────────────────────────────────
# [OPTIONAL] Parallel embed worker lanes (CPU-scaled default clamped 2-32).
AXON_EMBED_LANES=

# [OPTIONAL] Parallel ingest worker lanes (clamped 1-16). Default: 2.
AXON_INGEST_LANES=2

# [OPTIONAL] Max concurrent documents in the embed pipeline.
# Default: CPU count clamped 2-8. Env override is clamped 1-64.
AXON_EMBED_DOC_CONCURRENCY=

# [OPTIONAL] Per-document embed timeout in seconds. Default: 300.
# Must exceed TEI worst-case retry budget (~167s). 300s gives ~133s headroom.
AXON_EMBED_DOC_TIMEOUT_SECS=300

# [OPTIONAL] Max pending crawl jobs before new submissions are rejected (0 = unlimited). Default: 100.
AXON_MAX_PENDING_CRAWL_JOBS=100
# [OPTIONAL] Max pending embed jobs before new submissions are rejected (0 = unlimited). Default: 50.
AXON_MAX_PENDING_EMBED_JOBS=50
# [OPTIONAL] Max pending extract jobs before new submissions are rejected (0 = unlimited). Default: 50.
AXON_MAX_PENDING_EXTRACT_JOBS=50
# [OPTIONAL] Max pending ingest jobs before new submissions are rejected (0 = unlimited). Default: 50.
AXON_MAX_PENDING_INGEST_JOBS=50

# [OPTIONAL] Seconds before a running job is considered stale. Default: 300.
AXON_JOB_STALE_TIMEOUT_SECS=300

# [OPTIONAL] Grace period in seconds before a stale job is reclaimed. Default: 60.
AXON_JOB_STALE_CONFIRM_SECS=60

# [OPTIONAL] Timeout for CLI --wait job polling in seconds. Default: 300.
AXON_JOB_WAIT_TIMEOUT_SECS=300

# [OPTIONAL] Queue-depth summary log interval in seconds for worker processes.
# Default: 60. Set to 0 to disable.
AXON_QUEUE_SUMMARY_SECS=60


# ── MCP Server ────────────────────────────────────────────────────────────────
# [OPTIONAL] Generic CLI server-mode endpoint. When set, supported stateful CLI
# commands (status/scrape/crawl/extract/embed/ingest/sessions/screenshot) call
# this running axon server instead of writing host-local state directly.
# Default: unset (local CLI execution). Typical local server:
# AXON_SERVER_URL=http://127.0.0.1:8001
AXON_SERVER_URL=

# [OPTIONAL] Force local CLI execution even when AXON_SERVER_URL is configured.
# Equivalent CLI flag: --local.
# AXON_LOCAL_MODE=false

# [OPTIONAL] Allow sending AXON_MCP_HTTP_TOKEN over plaintext HTTP to a
# non-loopback host. Leave unset; prefer HTTPS for remote servers.
# AXON_SERVER_INSECURE=1

# [OPTIONAL] MCP transport override for `axon mcp` / `axon serve mcp`.
# Values: stdio, http, both. Defaults are command-specific.
AXON_MCP_TRANSPORT=

# [OPTIONAL] MCP HTTP server port. Default: 8001.
AXON_MCP_HTTP_PORT=8001

# [OPTIONAL] MCP HTTP bind address. Default: 127.0.0.1.
# Non-loopback binds require AXON_MCP_HTTP_TOKEN or AXON_MCP_AUTH_MODE=oauth.
AXON_MCP_HTTP_HOST=127.0.0.1

# [OPTIONAL] Bearer token required on all MCP HTTP requests.
# In OAuth mode, this optional static token continues to work alongside OAuth JWTs.
# In bearer mode, non-loopback binds require this to be set.
AXON_MCP_HTTP_TOKEN=

# [OPTIONAL] MCP auth mode. Default: bearer. Set to oauth to enable Google
# OAuth, dynamic client registration, JWT bearer validation, and OAuth metadata.
AXON_MCP_AUTH_MODE=bearer

# [REQUIRED when AXON_MCP_AUTH_MODE=oauth] Public origin for OAuth metadata.
# Example: https://axon.example.com
AXON_MCP_PUBLIC_URL=

# [REQUIRED when AXON_MCP_AUTH_MODE=oauth] Google OAuth app credentials.
AXON_MCP_GOOGLE_CLIENT_ID=
AXON_MCP_GOOGLE_CLIENT_SECRET=

# [REQUIRED when AXON_MCP_AUTH_MODE=oauth] Admin email allowed by the auth layer.
AXON_MCP_AUTH_ADMIN_EMAIL=

# [OPTIONAL] Extra OAuth redirect URIs. Claude's MCP callback is included by
# default; append additional comma-separated callbacks here.
AXON_MCP_AUTH_ALLOWED_REDIRECT_URIS=

# [OPTIONAL] Comma-separated allowed Origins for MCP HTTP CORS.
# Example: https://axon.example.com
AXON_MCP_ALLOWED_ORIGINS=

# [OPTIONAL] Directory for MCP JSON artifacts (response_mode=path).
# Default: $AXON_DATA_DIR/artifacts
AXON_MCP_ARTIFACT_DIR=

# [OPTIONAL] Payload size threshold (bytes) for auto-inline mode. Default: 8192.
# Set to 0 to disable auto-inline.
AXON_INLINE_BYTES_THRESHOLD=8192

# [OPTIONAL] Comma-separated allowlist of local filesystem roots for MCP embed.
# Example: /home/yourname/docs,/home/yourname/projects
# Leave unset to disable local file embedding via MCP.
AXON_MCP_EMBED_ALLOWED_ROOTS=

# [OPTIONAL] Max bytes per local file embedding request via MCP.
AXON_MCP_EMBED_MAX_LOCAL_BYTES=10485760


# ── Gemini Headless LLM ───────────────────────────────────────────────────────
# Gemini headless powers ask, research, evaluate, suggest, extract fallback, and debug.
# AXON_HEADLESS_GEMINI_MODEL optionally overrides gemini-3.1-flash-lite-preview.
AXON_HEADLESS_GEMINI_MODEL=
# [OPTIONAL] Gemini CLI command. Default: gemini.
AXON_HEADLESS_GEMINI_CMD=gemini
# [OPTIONAL] Gemini headless auth source HOME. Defaults to process HOME.
AXON_HEADLESS_GEMINI_HOME=
# [OPTIONAL] Runtime-only max concurrent LLM completion requests. Default: 4.
AXON_LLM_COMPLETION_CONCURRENCY=4
# [OPTIONAL] Runtime-only per-completion timeout in seconds. Default: 300.
AXON_LLM_COMPLETION_TIMEOUT_SECS=300

# [OPTIONAL] Passed through to the isolated Gemini CLI process when set.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_GENAI_USE_VERTEXAI=


# ── Session Ingest ────────────────────────────────────────────────────────────
# [OPTIONAL] Max bytes per session ingest payload. Default: 20971520.
AXON_SESSION_INGEST_MAX_BYTES=20971520


# ── Chrome / Browser ──────────────────────────────────────────────────────────
# [REQUIRED for --render-mode chrome/auto-switch] CDP endpoint for headless_browser.
AXON_CHROME_REMOTE_URL=http://axon-chrome:6000

# [OPTIONAL] Proxy URL for Chrome requests.
AXON_CHROME_PROXY=

# [OPTIONAL] User-Agent override for Chrome requests.
AXON_CHROME_USER_AGENT=

# [OPTIONAL] Enable browser diagnostics artifact collection. Default: false.
AXON_CHROME_DIAGNOSTICS=false

# [OPTIONAL] Output directory for browser diagnostics. Default: $AXON_DATA_DIR/chrome-diagnostics.
AXON_CHROME_DIAGNOSTICS_DIR=

# [OPTIONAL] Enable event-log capture in browser diagnostics. Default: false.
AXON_CHROME_DIAGNOSTICS_EVENTS=false

# [OPTIONAL] Enable screenshot capture in browser diagnostics. Default: false.
AXON_CHROME_DIAGNOSTICS_SCREENSHOT=false


# ── Output & CLI ──────────────────────────────────────────────────────────────
# [OPTIONAL] Directory for saved markdown/HTML output files.
# Default: $AXON_DATA_DIR/output when AXON_DATA_DIR is set; otherwise .cache/axon-rust/output.
AXON_OUTPUT_DIR=

# [OPTIONAL] Directory where the upstream spider crate stores crawl-time
# screenshots (chrome_store_page). Read by spider, not axon. Defaults to
# ./storage/ relative to CWD; redirect into .cache to keep the repo clean.
SCREENSHOT_DIRECTORY=.cache/axon-rust/screenshots

# [OPTIONAL] Tracing filter for console and file logs. RUST_LOG wins when set.
AXON_LOG_LEVEL=info
RUST_LOG=

# [OPTIONAL] Size-rotated JSON log file settings.
# Defaults: $AXON_DATA_DIR/logs, axon.log, 10485760 bytes, 3 archives.
AXON_LOG_DIR=
AXON_LOG_FILE=axon.log
AXON_LOG_MAX_BYTES=10485760
AXON_LOG_MAX_FILES=3

# [OPTIONAL] Log full search/research query text instead of redacted previews.
# Also enabled when AXON_LOG_LEVEL is debug or trace.
AXON_LOG_FULL_QUERIES=false

# [OPTIONAL] Disable ANSI color output (any non-empty value disables color).
AXON_NO_COLOR=

# [OPTIONAL] Prevent destructive cache wipes during some flows.
AXON_NO_WIPE=

# [OPTIONAL] Enable detailed per-domain breakdown in the domains command.
AXON_DOMAINS_DETAILED=

# [OPTIONAL] Max points scanned for detailed per-domain breakdown. Default: 10000000.
AXON_DOMAINS_DETAILED_LIMIT=10000000

# [OPTIONAL] Facet limit for sources/domains listing commands.
AXON_SOURCES_FACET_LIMIT=100000
AXON_DOMAINS_FACET_LIMIT=100000
