# Axon env: secrets, URLs, auth/bootstrap, compose interpolation only.
# Tuning knobs (AXON_ASK_*, AXON_HYBRID_*, TEI_MAX_*, etc.) live in ~/.axon/config.toml.

# ── Data + service URLs ─────────────────────────────────────────────────────
AXON_DATA_DIR=
AXON_HOME=
QDRANT_URL=http://127.0.0.1:53333
TEI_URL=http://127.0.0.1:52000
AXON_CHROME_REMOTE_URL=http://127.0.0.1:6000
AXON_SERVER_URL=http://127.0.0.1:8001
AXON_COLLECTION=axon

# ── MCP HTTP server ─────────────────────────────────────────────────────────
AXON_MCP_HTTP_HOST=127.0.0.1
AXON_MCP_HTTP_PORT=8001
# Local bearer setup generates this value; fill manually only when not using setup init.
AXON_MCP_HTTP_TOKEN=
AXON_MCP_AUTH_MODE=bearer
# Required only when AXON_MCP_AUTH_MODE=oauth.
AXON_MCP_PUBLIC_URL=
AXON_MCP_GOOGLE_CLIENT_ID=
AXON_MCP_GOOGLE_CLIENT_SECRET=
AXON_MCP_AUTH_ADMIN_EMAIL=
AXON_MCP_AUTH_ALLOWED_REDIRECT_URIS=
AXON_MCP_ALLOWED_ORIGINS=

# ── MCP Google OAuth (optional — required for HTTP OAuth login) ──────────────
# OAuth client ID and secret from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Full redirect URI override (recommended for public deployments)
# Example: https://axon.tootie.tv/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Space-delimited scopes requested from Google (default shown)
GOOGLE_OAUTH_SCOPES="openid email profile"
# Issuer advertised by local OAuth broker metadata
GOOGLE_OAUTH_BROKER_ISSUER=http://127.0.0.1:8001

# ── Ingest credentials ──────────────────────────────────────────────────────
TAVILY_API_KEY=
GITHUB_TOKEN=
GITLAB_TOKEN=
GITEA_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
HF_TOKEN=

# ── LLM runtime (ask / evaluate / suggest / extract / research) ─────────────
# Default: Gemini headless. For llama.cpp's OpenAI-compatible server, set:
# AXON_LLM_BACKEND=openai-compat
AXON_LLM_BACKEND=

# OpenAI-compatible endpoint settings (llama.cpp server, LM Studio, etc.).
# Base URL is the API root; do not include /chat/completions.
AXON_OPENAI_BASE_URL=
AXON_OPENAI_MODEL=
AXON_OPENAI_API_KEY=

# Gemini headless settings
# Pick one auth path:
#   - OAuth (default): leave GEMINI_API_KEY blank, ensure $HOME/.gemini exists
#   - API key: set GEMINI_API_KEY
GEMINI_API_KEY=
# Docker bind mount: host dir holding the OAuth credentials for the gemini CLI.
GEMINI_HOME=
# Runtime override: dir axon copies OAuth files FROM into an isolated temp HOME
# per Gemini invocation. Defaults to $HOME. Set only if Gemini creds live elsewhere.
AXON_HEADLESS_GEMINI_HOME=
# Path to the gemini binary. Defaults to PATH lookup of `gemini`.
AXON_HEADLESS_GEMINI_CMD=
# Gemini model override (e.g. gemini-2.5-flash-exp). Defaults to gemini CLI's choice.
AXON_HEADLESS_GEMINI_MODEL=

# ── HTTP behavior ───────────────────────────────────────────────────────────
# General-purpose User-Agent for all HTTP requests (API calls, vertical extractors,
# web scraping). Falls back to a Firefox browser UA when unset.
# AXON_CHROME_USER_AGENT inherits this value when it is not set explicitly.
AXON_USER_AGENT=
# Chrome-specific User-Agent override (Spider crawl + Chrome render paths).
# Falls back to AXON_USER_AGENT, then the built-in browser default.
AXON_CHROME_USER_AGENT=

# ── Logging ─────────────────────────────────────────────────────────────────
# Full path to active log file. Rotated siblings (.1, .2, ...) live in the same dir.
# Default: $AXON_DATA_DIR/logs/axon.log
AXON_LOG_PATH=

# ── Compose interpolation (Docker only) ─────────────────────────────────────
AXON_IMAGE=
AXON_MCP_HTTP_PUBLISH=8001
TEI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
TEI_HTTP_PORT=52000
TEI_SERVER_MAX_CLIENT_BATCH_SIZE=96
NVIDIA_VISIBLE_DEVICES=0
CUDA_VISIBLE_DEVICES=0
