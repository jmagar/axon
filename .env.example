# Axon production environment template.
# Copy to ~/.axon/.env. This file is for URLs, secrets, auth/runtime
# bootstrap, and Docker Compose interpolation only.
#
# Non-secret tuning belongs in ~/.axon/config.toml. See config.example.toml.
# Precedence: CLI flags > process env / this file > config.toml > defaults.

# ── Shared Axon Home ─────────────────────────────────────────────────────────
# Canonical appdata root used by the installer, CLI, Docker Compose, web panel,
# and Claude plugin. Leave unset to use ${HOME}/.axon.
AXON_HOME=${HOME}/.axon
AXON_DATA_DIR=
AXON_SQLITE_PATH=
AXON_ENV_FILE=
AXON_CONFIG_PATH=

# Host CLI client/server mode. The server container clears this internally.
AXON_SERVER_URL=http://127.0.0.1:8001
AXON_LOCAL_MODE=false
AXON_SERVER_INSECURE=

# ── Docker Compose Interpolation ─────────────────────────────────────────────
AXON_IMAGE=ghcr.io/jmagar/axon:latest
AXON_MCP_HTTP_PUBLISH=127.0.0.1:8001

# TEI service settings consumed by Docker Compose.
HF_TOKEN=
TEI_HTTP_PORT=52000
TEI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
TEI_MAX_CONCURRENT_REQUESTS=32
TEI_MAX_BATCH_TOKENS=65536
TEI_MAX_BATCH_REQUESTS=64
TEI_MAX_CLIENT_BATCH_SIZE=96
TEI_POOLING=last-token
TEI_TOKENIZATION_WORKERS=8
NVIDIA_VISIBLE_DEVICES=0
CUDA_VISIBLE_DEVICES=0

# ── Service URLs ─────────────────────────────────────────────────────────────
# Host-facing defaults for the CLI, installer, and plugin processes. Docker
# service DNS names stay in docker-compose.yaml service environment only.
QDRANT_URL=http://127.0.0.1:53333
TEI_URL=http://127.0.0.1:52000
AXON_CHROME_REMOTE_URL=http://127.0.0.1:6000
AXON_CHROME_PROXY=

# ── MCP / HTTP Auth ──────────────────────────────────────────────────────────
AXON_MCP_TRANSPORT=
AXON_MCP_HTTP_HOST=127.0.0.1
AXON_MCP_HTTP_PORT=8001
AXON_MCP_HTTP_TOKEN=

# bearer or oauth. Non-loopback HTTP binds require auth.
AXON_MCP_AUTH_MODE=bearer
AXON_MCP_PUBLIC_URL=
AXON_MCP_GOOGLE_CLIENT_ID=
AXON_MCP_GOOGLE_CLIENT_SECRET=
AXON_MCP_AUTH_ADMIN_EMAIL=
AXON_MCP_AUTH_ALLOWED_REDIRECT_URIS=
AXON_MCP_ALLOWED_ORIGINS=

# Artifact and local-file embedding runtime paths.
AXON_MCP_ARTIFACT_DIR=
AXON_MCP_EMBED_ALLOWED_ROOTS=
AXON_MCP_EMBED_MAX_LOCAL_BYTES=

# ── Gemini CLI Runtime ───────────────────────────────────────────────────────
# Production LLM operations use Gemini CLI only. Setup checks can only prove
# the CLI is present; the first axon ask smoke proves auth and completion.
AXON_HEADLESS_GEMINI_CMD=gemini
AXON_HEADLESS_GEMINI_HOME=
AXON_HEADLESS_GEMINI_MODEL=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_GENAI_USE_VERTEXAI=

# ── Optional External Credentials ────────────────────────────────────────────
TAVILY_API_KEY=
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Output And Logs ──────────────────────────────────────────────────────────
AXON_OUTPUT_DIR=
SCREENSHOT_DIRECTORY=.cache/axon-rust/screenshots
AXON_LOG_DIR=
AXON_LOG_FILE=axon.log
RUST_LOG=
